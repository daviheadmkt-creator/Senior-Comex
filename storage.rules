
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    /**
     * @description Regras para a pasta de processos.
     * Permite upload se:
     * - O utilizador estiver autenticado.
     * - O ficheiro tiver menos de 10MB.
     * - O tipo de ficheiro for Imagem, PDF, XML ou binário genérico (fallback).
     */
    match /processos/{processoId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024
                   && (
                     request.resource.contentType.matches('image/.*') || 
                     request.resource.contentType == 'application/pdf' || 
                     request.resource.contentType == 'text/xml' || 
                     request.resource.contentType == 'application/xml' ||
                     request.resource.contentType == 'application/octet-stream'
                   );
    }
  }
}
