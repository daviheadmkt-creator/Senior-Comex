
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow any authenticated user to read or write files within any process folder.
    // This is a permissive rule for development. For production, you might want to add
    // logic to verify that the user is associated with the 'processoId'.
    match /processos/{processoId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}

    