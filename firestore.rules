/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-generated content (audit logs, reports),
 * allowing users to manage their own data. Partners are treated as a top level collection that is publicly readable, but only
 * writeable by administrators.
 *
 * Data Structure:
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs, owned by the user.
 * - /users/{userId}/reports/{reportId}: Stores reports, owned by the user.
 * - /partners/{partnerId}: Stores partner information, publicly readable, owner writeable.
 *
 * Key Security Decisions:
 * - Listing of all users is disallowed for privacy.
 * - AuditLogs and Reports are strictly owned by the user ID in the path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to determine if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to determine if the user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to determine if the user is the existing owner of the document
    function isExistingOwner(userId) {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }

    /**
     * @description Controls access to audit logs for individual users.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User A can create a log under their own user ID: /users/userA/auditLogs/log1 with request.auth.uid == "userA" and request.resource.data.userId == "userA".
     * @deny (create) User A cannot create a log under User B's user ID: /users/userB/auditLogs/log1 with request.auth.uid == "userA".
     * @allow (get) User A can read log under their own user ID: /users/userA/auditLogs/log1 with request.auth.uid == "userA".
     * @deny (get) User A cannot read log under User B's user ID: /users/userB/auditLogs/log1 with request.auth.uid == "userA".
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to reports generated by individual users.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User A can create a report under their own user ID: /users/userA/reports/report1 with request.auth.uid == "userA" and request.resource.data.generatedByUserId == "userA".
     * @deny (create) User A cannot create a report under User B's user ID: /users/userB/reports/report1 with request.auth.uid == "userA".
     * @allow (get) User A can read report under their own user ID: /users/userA/reports/report1 with request.auth.uid == "userA".
     * @deny (get) User A cannot read report under User B's user ID: /users/userB/reports/report1 with request.auth.uid == "userA".
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.generatedByUserId == userId;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to partner information.
     * @path /partners/{partnerId}
     * @allow (get, list) Everyone can read partner information.
     * @deny (create, update, delete) Only an administrator can modify partner information (TODO: Add Admin Role).
     * @principle Public read access with restricted write access.
     */
    match /partners/{partnerId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }
}