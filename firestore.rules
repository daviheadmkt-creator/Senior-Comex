/**
 * @file Firestore Security Rules for SeniorComex Application
 * @description This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles. User ID in path must match the document's 'id' field.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for a specific user. Only the owning user can manage these logs.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by a specific user. Only the owning user can manage these reports.
 * - /partners/{partnerId}: Stores partner information. Public read, owner-only write.
 *
 * Key Security Decisions:
 * - Users cannot be listed.
 * - All writes are protected by authorization checks.
 * - Data consistency between the path and the document's internal fields is enforced.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the /users/{userId} collection, ensuring only the user can read/write their own profile.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile if request.auth.uid == 'user123'.
     * @allow (get, update, delete) User with ID 'user123' can read/update/delete their profile if request.auth.uid == 'user123'.
     * @deny (create) User with ID 'user123' cannot create a profile with a different ID.
     * @deny (update, delete) User with ID 'user456' cannot update/delete user 'user123's profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // Listing users is not permitted.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures the /users/{userId}/auditLogs/{auditLogId} collection, ensuring only the owning user can manage their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User with ID 'user123' can create audit logs under their profile.
     * @allow (get, list, update, delete) User with ID 'user123' can manage their own audit logs.
     * @deny (create) User with ID 'user456' cannot create audit logs under user 'user123's profile.
     * @deny (get, list, update, delete) User with ID 'user456' cannot manage user 'user123's audit logs.
     * @principle Enforces document ownership and restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures the /users/{userId}/reports/{reportId} collection, ensuring only the owning user can manage their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User with ID 'user123' can create reports under their profile.
     * @allow (get, list, update, delete) User with ID 'user123' can manage their own reports.
     * @deny (create) User with ID 'user456' cannot create reports under user 'user123's profile.
     * @deny (get, list, update, delete) User with ID 'user456' cannot manage user 'user123's reports.
     * @principle Enforces document ownership and restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures the /partners/{partnerId} collection, allowing public read access but restricting writes to authenticated users.
     * @path /partners/{partnerId}
     * @allow (get, list) Any user, authenticated or not, can read partner information.
     * @allow (create) Authenticated user can create a partner.
     * @allow (update, delete) Authenticated user can update/delete a partner.
     * @deny (create) Unauthenticated user cannot create a partner.
     * @deny (update, delete) Unauthenticated user cannot update/delete a partner.
     * @principle Allows public read access with owner-only writes for partner information.
     */
    match /partners/{partnerId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isExisting() {
          return resource != null;
      }
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isExisting();
      allow delete: if isSignedIn() && isExisting();
    }
  }
}