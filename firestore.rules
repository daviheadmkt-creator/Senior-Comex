/**
 * @file Firebase Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports,
 * ensuring that users can only access their own data. Partner data is not user-specific and requires separate considerations for access control.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs related to a specific user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by a specific user.
 * - /partners/{partnerId}: Stores partner information.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data.
 * - Audit logs and reports are strictly owned by the user and cannot be accessed by others.
 * - Listing of audit logs and reports is allowed only for the owner.
 * - No listing of users is allowed.
 * - Partner data needs more specific authorization based on roles or other criteria.
 *
 * Denormalization for Authorization:
 * - The `userId` is embedded in the paths for auditLogs and reports, avoiding the need for `get()` calls to verify ownership.
 *
 * Structural Segregation:
 * - Audit logs and reports are stored in separate subcollections under the user document, ensuring clear ownership and simplifying access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user123' can create their own profile document at /users/user123.
     * @allow (get) - User with UID 'user123' can read their own profile document at /users/user123.
     * @allow (update) - User with UID 'user123' can update their own profile document at /users/user123.
     * @allow (delete) - User with UID 'user123' can delete their own profile document at /users/user123.
     * @deny (create) - User with UID 'user456' cannot create a profile document at /users/user123.
     * @deny (get) - User with UID 'user456' cannot read the profile document at /users/user123.
     * @deny (update) - User with UID 'user456' cannot update the profile document at /users/user123.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to audit logs for each user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) - User with UID 'user123' can create an audit log entry under /users/user123/auditLogs/log1.
     * @allow (get) - User with UID 'user123' can read an audit log entry under /users/user123/auditLogs/log1.
     * @allow (list) - User with UID 'user123' can list audit log entries under /users/user123/auditLogs.
     * @deny (create) - User with UID 'user456' cannot create an audit log entry under /users/user123/auditLogs/log1.
     * @deny (get) - User with UID 'user456' cannot read an audit log entry under /users/user123/auditLogs/log1.
     * @deny (update) - User with UID 'user123' cannot update an audit log entry under /users/user123/auditLogs/log1.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to reports generated by each user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) - User with UID 'user123' can create a report under /users/user123/reports/report1.
     * @allow (get) - User with UID 'user123' can read a report under /users/user123/reports/report1.
     * @allow (list) - User with UID 'user123' can list reports under /users/user123/reports.
     * @deny (create) - User with UID 'user456' cannot create a report under /users/user123/reports/report1.
     * @deny (get) - User with UID 'user456' cannot read a report under /users/user123/reports/report1.
     * @deny (update) - User with UID 'user123' cannot update a report under /users/user123/reports/report1.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

       /**
     * @description Controls access to partners information.
     * @path /partners/{partnerId}
     * @allow (get) - Any signed-in user can read a partner's information.
     * @allow (list) - Any signed-in user can list partners.
     * @deny (create) - No one can create a partner document. // TODO: Add role-based access for partner creation.
     * @deny (update) - No one can update a partner document. // TODO: Add role-based access for partner updates.
     * @deny (delete) - No one can delete a partner document. // TODO: Add role-based access for partner deletion.
     * @principle Controls access to partner data. Requires further role-based access implementation.
     */
    match /partners/{partnerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false; // TODO: Add role-based access for partner creation.
      allow update: if false; // TODO: Add role-based access for partner updates.
      allow delete: if false; // TODO: Add role-based access for partner deletion.
    }


    // --- Helper Functions ---

    /**
     * @description Checks if the request is authenticated.
     * @return {boolean} True if the request is authenticated, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the request is made by the owner of the document.
     * @param {string} userId The user ID to compare against the request's auth UID.
     * @return {boolean} True if the request is made by the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

   /**
     * @description Checks if the request is made by the owner of an EXISTING document.
     * @param {string} userId The user ID to compare against the request's auth UID.
     * @return {boolean} True if the request is made by the owner and the resource exists.
     */
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
  }
}