/**
 * @file Firestore Security Rules for SeniorComex application.
 *
 * @corePhilosophy This ruleset enforces a strict user-ownership model for user-related data (audit logs, reports),
 *                 allowing users to manage their own data while restricting access to others' data.
 *                 Partners data are publicly available for read, while only authenticated users can modify partners data.
 *
 * @dataStructure The data is organized hierarchically under the `/users/{userId}` collection, with
 *                subcollections for `/auditLogs` and `/reports`. Partners data is stored in the top-level `/partners/{partnerId}` collection.
 *
 * @keySecurityDecisions
 *   - Users cannot list all user documents.
 *   - Audit Logs and Reports are secured via path-based ownership. Only the owner (the user ID in the path) can access these subcollections.
 *   - Partners data is readable by anyone, but only authenticated users can modify it.
 *
 * @denormalizationForAuthorization Path-based ownership is used for AuditLog and Report subcollections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Prevents listing all users.
     * @path /databases/{database}/documents/users
     * @allow N/A
     * @deny list: Always. Users should not be able to list all user documents.
     * @principle Prevents information leakage by disallowing user enumeration.
     */
    match /users {
      allow get: if false;
      allow list: if false;
    }

    /**
     * @description Controls access to individual user documents.
     * @path /databases/{database}/documents/users/{userId}
     * @allow (get) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can read their own profile.
     * @allow (create) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create their own profile.
     * @allow (update) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can update their own profile.
     * @allow (delete) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can delete their own profile.
     * @deny (get) User with ID 'randomId' cannot read the profile of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (create) User with ID 'randomId' cannot create a profile for user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (update) User with ID 'randomId' cannot update the profile of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (delete) User with ID 'randomId' cannot delete the profile of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to audit logs for each user.
     * @path /databases/{database}/documents/users/{userId}/auditLogs/{auditLogId}
     * @allow (get) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can read their own audit logs.
     * @allow (list) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can list their own audit logs.
     * @allow (create) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create audit logs under their own profile.
     * @allow (update) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can update their own audit logs.
     * @allow (delete) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can delete their own audit logs.
     * @deny (get) User with ID 'randomId' cannot read audit logs of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (list) User with ID 'randomId' cannot list audit logs of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (create) User with ID 'randomId' cannot create audit logs under the profile of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (update) User with ID 'randomId' cannot update audit logs of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (delete) User with ID 'randomId' cannot delete audit logs of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @principle Enforces user-ownership for audit log data via path-based ownership.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to reports generated by each user.
     * @path /databases/{database}/documents/users/{userId}/reports/{reportId}
     * @allow (get) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can read their own reports.
     * @allow (list) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can list their own reports.
     * @allow (create) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create reports under their own profile.
     * @allow (update) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can update their own reports.
     * @allow (delete) User with ID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can delete their own reports.
     * @deny (get) User with ID 'randomId' cannot read reports of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (list) User with ID 'randomId' cannot list reports of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (create) User with ID 'randomId' cannot create reports under the profile of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (update) User with ID 'randomId' cannot update reports of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (delete) User with ID 'randomId' cannot delete reports of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @principle Enforces user-ownership for report data via path-based ownership.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to partner information. Partners data is readable by anyone, but only authenticated users can modify it.
     * @path /databases/{database}/documents/partners/{partnerId}
     * @allow (get) Any user can read partner information.
     * @allow (list) Any user can list partner information.
     * @allow (create) Only authenticated users can create partner information.
     * @allow (update) Only authenticated users can update partner information.
     * @allow (delete) Only authenticated users can delete partner information.
     * @deny (create) Non-authenticated users cannot create partner information.
     * @deny (update) Non-authenticated users cannot update partner information.
     * @deny (delete) Non-authenticated users cannot delete partner information.
     */
    match /partners/{partnerId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}