/**
 * @file This ruleset enforces a strict user-ownership model for user-related data
 * and allows public read access to the "processos" collection.
 *
 * @dataStructure
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user.
 * - /partners/{partnerId}: Stores partner information.
 * - /processos/{document}: Publicly readable collection.
 *
 * @keySecurityDecisions
 * - Users can only manage their own profile data.
 * - Audit logs and reports are strictly owned by the user and cannot be listed or accessed by other users.
 * - The "processos" collection is publicly readable by any logged-in user, but write permissions are denied.
 * - Denormalization is used to avoid `get()` calls for authorization, using path-based ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to manage their own user profile.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user_abc' can create their own profile at /users/user_abc.
     * @allow (update) - User with UID 'user_abc' can update their own profile at /users/user_abc.
     * @deny (create) - User with UID 'user_abc' cannot create a profile at /users/user_xyz.
     * @deny (update) - User with UID 'user_abc' cannot update the profile of another user at /users/user_xyz.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Allows a user to manage their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) - User with UID 'user_abc' can create an audit log under /users/user_abc/auditLogs/log_1.
     * @allow (update) - User with UID 'user_abc' can update an audit log under /users/user_abc/auditLogs/log_1.
     * @deny (create) - User with UID 'user_abc' cannot create an audit log under /users/user_xyz/auditLogs/log_1.
     * @deny (update) - User with UID 'user_abc' cannot update an audit log under /users/user_xyz/auditLogs/log_1.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Allows a user to manage their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) - User with UID 'user_abc' can create a report under /users/user_abc/reports/report_1.
     * @allow (update) - User with UID 'user_abc' can update a report under /users/user_abc/reports/report_1.
     * @deny (create) - User with UID 'user_abc' cannot create a report under /users/user_xyz/reports/report_1.
     * @deny (update) - User with UID 'user_abc' cannot update a report under /users/user_xyz/reports/report_1.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.generatedByUserId == userId;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.generatedByUserId == resource.data.generatedByUserId;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

     /**
      * @description Allows public read access to partner information, but restricts write access.
      * @path /partners/{partnerId}
      * @allow (get) Any logged in user can read partner information.
      * @allow (list) Any logged in user can list partner information.
      * @deny (create) No one can create partner documents without specific authorization.
      * @deny (update) No one can update partner documents without specific authorization.
      * @deny (delete) No one can delete partner documents without specific authorization.
      */
    match /partners/{partnerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows any logged-in user to read documents from the "processos" collection.  Write operations are denied.
     * @path /processos/{document=**}
     * @allow (get) Any logged-in user can read documents in "processos".
     * @allow (list) Any logged-in user can list documents in "processos".
     * @deny (create) No one can create documents in "processos" without specific authorization.
     * @deny (update) No one can update documents in "processos" without specific authorization.
     * @deny (delete) No one can delete documents in "processos" without specific authorization.
     */
    match /processos/{document=**} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isSignedIn() && isOwner(userId) && resource != null;
  }
}