/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user-related data and allows open access for partners.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Only the authenticated user can read/write their own profile.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Only the authenticated user can read/write their own audit logs.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Only the authenticated user can read/write their own reports.
 * - /partners/{partnerId}: Stores partner information. Public read/write access is granted to this collection.
 *
 * Key Security Decisions:
 * - User data is strictly controlled: only the authenticated user can access their own data.
 * - Audit logs and reports are subcollections of users, inheriting the user-ownership model.
 * - Partner data is publicly accessible, as per the prompt's implied requirements.
 *
 *  Authorization Independence is achieved by relating AuditLog and Report documents to users using path based ownership (`/users/{userId}/auditLogs/{auditLogId}` and `/users/{userId}/reports/{reportId}`).  This approach avoids the need for `get()` calls to retrieve parent document data during authorization, ensuring atomic operations and easier debugging. QAPs (Rules are not Filters) are supported by the segregation of data into dedicated collections, each with well-defined security requirements, and all documents in a collection share the same security requirements.  This prevents the need for complex filtering logic in the security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for user profiles.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their own profile.
     * @deny (create) User with ID 'user123' cannot create a profile for 'user456'.
     * @allow (get) User with ID 'user123' can read their own profile.
     * @deny (get) User with ID 'user123' cannot read profile for 'user456'.
     * @allow (update) User with ID 'user123' can update their own profile.
     * @deny (update) User with ID 'user123' cannot update the profile for 'user456'.
     * @allow (delete) User with ID 'user123' can delete their own profile.
     * @deny (delete) User with ID 'user123' cannot delete the profile for 'user456'.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // Listing users is generally not allowed.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User with ID 'user123' can create an audit log under their profile.
     * @deny (create) User with ID 'user123' cannot create an audit log under 'user456's profile.
     * @allow (get) User with ID 'user123' can read their own audit log.
     * @deny (get) User with ID 'user123' cannot read audit log for 'user456'.
     * @allow (update) User with ID 'user123' can update their own audit log.
     * @deny (update) User with ID 'user123' cannot update the audit log for 'user456'.
     * @allow (delete) User with ID 'user123' can delete their own audit log.
     * @deny (delete) User with ID 'user123' cannot delete the audit log for 'user456'.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
        function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User with ID 'user123' can create a report under their profile.
     * @deny (create) User with ID 'user123' cannot create a report under 'user456's profile.
     * @allow (get) User with ID 'user123' can read their own report.
     * @deny (get) User with ID 'user123' cannot read report for 'user456'.
     * @allow (update) User with ID 'user123' can update their own report.
     * @deny (update) User with ID 'user123' cannot update the report for 'user456'.
     * @allow (delete) User with ID 'user123' can delete their own report.
     * @deny (delete) User with ID 'user123' cannot delete the report for 'user456'.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
            function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
    /**
     * @description Allows public read and write access to partner data.
     * @path /partners/{partnerId}
     * @allow (get) Any user can read partner data.
     * @allow (list) Any user can list partner data.
     * @allow (create) Any user can create partner data.
     * @allow (update) Any user can update partner data.
     * @allow (delete) Any user can delete partner data.
     * @principle Allows open read and write access to partner data.
     */
    match /partners/{partnerId} {
       allow get: if true;
       allow list: if true;
       allow create: if true;
       allow update: if resource != null;
       allow delete: if resource != null;
    }
  }
}