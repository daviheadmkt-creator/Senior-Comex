/**
 * @file Overview
 * This ruleset enforces a hybrid security model combining user-ownership with administrative override capabilities.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles. The 'funcao' field within the user document determines the user's role (e.g., "Administrador").
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs related to specific users, owned by that user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by specific users, owned by that user.
 * - /partners/{partnerId}: Stores partner information.
 *
 * Key Security Decisions:
 * - User Collection: User creation is allowed either by the user themselves (self-registration) or by an administrator. Updates and deletes are similarly restricted to owners and administrators.
 * - Subcollections (/auditLogs, /reports):  Access is restricted to the owning user and administrators.
 * - Partners Collection: Read access is public to signed-in users, but write access is prohibited.
 *
 * Denormalization for Authorization:
 * - The 'funcao' field is stored directly on the user document to avoid needing a separate lookup to determine admin status. This denormalization enables the `isAdmin()` function, which allows for simpler and more efficient security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the requesting user has the 'Administrador' role.
     * @returns {bool} True if the user is an administrator, false otherwise.
     */
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Administrador';
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Security rules for the /users/{userId} collection.
     * @path /users/{userId}
     * @allow (create) User with auth.uid == userId can create their own profile. Admin can create as well.
     * @deny (create) User attempts to create a profile with a different userId.
     * @allow (get) User with auth.uid == userId can read their own profile.
     * @deny (get) User attempts to read a profile with a different userId.
     * @allow (update) User with auth.uid == userId can update their own profile. Admin can update as well.
     * @deny (update) User attempts to update a profile with a different userId.
     * @allow (delete) User with auth.uid == userId can delete their own profile. Admin can delete as well.
     * @deny (delete) User attempts to delete a profile with a different userId.
     * @principle Enforces document ownership for writes and allows self-creation.
     */
    match /users/{userId} {
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow get: if isOwner(userId);
      allow list: if isAdmin();
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    /**
     * @description Security rules for the /users/{userId}/auditLogs/{auditLogId} collection.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User with auth.uid == userId can create an audit log entry under their profile.
     * @deny (create) User attempts to create an audit log entry under a different userId.
     * @allow (get) User with auth.uid == userId can read an audit log entry under their profile.
     * @deny (get) User attempts to read an audit log entry under a different userId.
     * @allow (update) User with auth.uid == userId can update an audit log entry under their profile.
     * @deny (update) User attempts to update an audit log entry under a different userId.
     * @allow (delete) User with auth.uid == userId can delete an audit log entry under their profile.
     * @deny (delete) User attempts to delete an audit log entry under a different userId.
     *  @principle Restricts access to a user's own audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow create: if isOwner(userId) || isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    /**
     * @description Security rules for the /users/{userId}/reports/{reportId} collection.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User with auth.uid == userId can create a report under their profile.
     * @deny (create) User attempts to create a report under a different userId.
     * @allow (get) User with auth.uid == userId can read a report under their profile.
     * @deny (get) User attempts to read a report under a different userId.
     * @allow (update) User with auth.uid == userId can update a report under their profile.
     * @deny (update) User attempts to update a report under a different userId.
     * @allow (delete) User with auth.uid == userId can delete a report under their profile.
     * @deny (delete) User attempts to delete a report under a different userId.
     * @principle Restricts access to a user's own reports.
     */
    match /users/{userId}/reports/{reportId} {
      allow create: if isOwner(userId) || isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    /**
     * @description Security rules for the /partners/{partnerId} collection.
     * @path /partners/{partnerId}
     * @allow (get) Any signed-in user can read partner information.
     * @allow (list) Any signed-in user can list partner information.
     * @deny (create) No one can create a partner document.
     * @deny (update) No one can update a partner document.
     * @deny (delete) No one can delete a partner document.
     * @principle Allows public read access for signed-in users, but restricts all write operations.
     */
    match /partners/{partnerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}