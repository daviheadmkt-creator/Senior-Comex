/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports.
 * All data is nested under /users/{userId}, ensuring that only the authenticated user can access their own data.
 * Audit logs and reports are stored as subcollections of user documents to enforce path-based ownership.
 * The /partners collection allows read and write access for all authenticated users.
 * Listing of users is denied to all users.
 *
 * Data Structure:
 * /users/{userId} (User profile information)
 * /users/{userId}/auditLogs/{auditLogId} (Audit logs for a specific user)
 * /users/{userId}/reports/{reportId} (Reports generated by a specific user)
 * /partners/{partnerId} (Partner information, accessible to all authenticated users)
 *
 * Key Security Decisions:
 * - Strict user-ownership for user profiles, audit logs, and reports.
 * - Partners collection is open to all authenticated users.
 * - Listing all users is explicitly denied.
 * - Uses path-based ownership to simplify security rules.
 * - Denormalization is not required because path-based ownership is used.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' creates their own profile.
     * @allow (get) User with ID 'user123' retrieves their profile.
     * @allow (update) User with ID 'user123' updates their own profile.
     * @allow (delete) User with ID 'user123' deletes their own profile.
     * @deny (create) User with ID 'user123' attempts to create a profile for 'user456'.
     * @deny (get) User with ID 'user123' attempts to retrieve the profile of 'user456'.
     * @deny (update) User with ID 'user123' attempts to update the profile of 'user456'.
     * @deny (delete) User with ID 'user123' attempts to delete the profile of 'user456'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Listing all users is not permitted.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && resource.data.id == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to audit logs for a specific user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User with ID 'user123' creates an audit log entry.
     * @allow (get) User with ID 'user123' retrieves an audit log entry.
     * @allow (update) User with ID 'user123' updates their audit log entry.
     * @allow (delete) User with ID 'user123' deletes their audit log entry.
     * @deny (create) User with ID 'user123' attempts to create an audit log for 'user456'.
     * @deny (get) User with ID 'user123' attempts to retrieve audit logs of 'user456'.
     * @deny (update) User with ID 'user123' attempts to update audit logs of 'user456'.
     * @deny (delete) User with ID 'user123' attempts to delete audit logs of 'user456'.
     * @principle Enforces path-based ownership for all audit log operations.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to reports generated by a specific user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User with ID 'user123' creates a report.
     * @allow (get) User with ID 'user123' retrieves their report.
     * @allow (update) User with ID 'user123' updates their report.
     * @allow (delete) User with ID 'user123' deletes their report.
     * @deny (create) User with ID 'user123' attempts to create a report for 'user456'.
     * @deny (get) User with ID 'user123' attempts to retrieve reports of 'user456'.
     * @deny (update) User with ID 'user123' attempts to update reports of 'user456'.
     * @deny (delete) User with ID 'user123' attempts to delete reports of 'user456'.
     * @principle Enforces path-based ownership for all report operations.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

     /**
     * @description Controls access to partner information. All authenticated users can read and write.
     * @path /partners/{partnerId}
     * @allow (create) Any authenticated user can create a partner.
     * @allow (get) Any authenticated user can retrieve partner information.
     * @allow (update) Any authenticated user can update partner information.
     * @allow (delete) Any authenticated user can delete partner information.
     * @principle Allows read and write access to partners for all authenticated users.
     */
    match /partners/{partnerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}