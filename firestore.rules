
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Helper function to check if a user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Controls access to user profile data.
     * @path /users/{userId}
     */
    match /users/{userId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      function isAdmin() {
          return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Administrador';
      }

      // Allow a user to create their own profile.
      allow create: if isSignedIn() && isOwner();
      // Allow a user to read their own profile.
      allow get: if isSignedIn() && isOwner();
      // Allow an admin to list users, otherwise deny.
      allow list: if isSignedIn() && isAdmin();
      // Allow a user to update their own profile.
      allow update: if isSignedIn() && isOwner();
      // Allow a user to delete their own profile.
      allow delete: if isSignedIn() && isOwner();
    }
    
    /**
     * @description Generic rule for collections accessible by any authenticated user.
     * @paths /partners/{partnerId}, /ports/{portId}, /terminals/{terminalId}, /processos/{processoId}
     */
    match /{collection}/{docId} 
      where collection in ['partners', 'ports', 'terminals', 'processos'] {
      // Any authenticated user can read, write, create, and delete documents in these collections.
      allow read, write, create, delete: if isSignedIn();
    }
  }
}
