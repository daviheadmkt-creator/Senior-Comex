/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles,
 * audit logs, and reports. Only authenticated users can access their own data.
 * Additionally, all documents have implicit existence checks on write.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data.  Only the user themselves can
 *   read or write their own profile.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs related to a
 *   specific user. Only the user can read or write their own audit logs.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by a specific
 *   user. Only the user can read or write their own reports.
 * - /partners/{partnerId}: Stores data about partners. Create, update, and delete operations are disallowed. Read operations are publicly accessible.
 *
 * Key Security Decisions:
 * - User listing is explicitly denied for security and privacy reasons.
 * - Role-based access control is not implemented in this initial version.
 * - Data validation is minimal, focusing on relational integrity and
 *   preventing unauthorized data modification.
 *
 * Denormalization for Authorization:
 *  - User ownership is enforced using path-based rules.
 *  - AuditLog and Report documents are related to users using path-based ownership: `/users/{userId}/auditLogs/{auditLogId}` and `/users/{userId}/reports/{reportId}`.
 *
 * Structural Segregation:
 *  - Audit logs and reports are stored as subcollections under user documents to
 *    clearly define ownership and simplify access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) - Authenticated user creates their own profile.
     * @allow (get, update, delete) - Authenticated user accesses their own profile.
     * @deny (list) - Prevents listing all users.
     * @deny (create, update, delete) - If the user is not authenticated or tries to access another user's profile.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to audit log entries for a specific user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) - Authenticated user creates an audit log entry under their own profile.
     * @allow (get, update, delete) - Authenticated user accesses their own audit log entries.
     * @deny (list) - If the user is not authenticated or tries to access another user's audit logs.
     * @principle Restricts access to a user's own audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to reports generated by a specific user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) - Authenticated user creates a report under their own profile.
     * @allow (get, update, delete) - Authenticated user accesses their own reports.
     * @deny (list) - If the user is not authenticated or tries to access another user's reports.
     * @principle Restricts access to a user's own reports.
     */
    match /users/{userId}/reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to partner documents.
     * @path /partners/{partnerId}
     * @allow (get, list) - Public read access.
     * @deny (create, update, delete) - No write access allowed.
     * @principle Provides public read access while restricting writes.
     */
    match /partners/{partnerId} {
        allow get, list: if true;
        allow create, update, delete: if false;
    }
  }
}