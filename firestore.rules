
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Helper function to check if a user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Controls access to user profile data.
     */
    match /users/{userId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      function isAdmin() {
          // Allow reading own document to check for the 'funcao' field.
          return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Administrador';
      }

      // Allow a user to create their own profile.
      allow create: if isSignedIn() && isOwner();
      // Allow a user to read their own profile.
      allow get: if isSignedIn() && isOwner();
      // Allow an admin to list users, otherwise deny.
      allow list: if isSignedIn() && isAdmin();
      // Allow a user to update their own profile.
      allow update: if isSignedIn() && isOwner();
      // Allow a user to delete their own profile.
      allow delete: if isSignedIn() && isOwner();
    }
    
    /**
     * @description Generic rules for business data collections.
     * Grants access to any authenticated user.
     */
    match /{collection}/{docId} where collection in ['partners', 'ports', 'terminals', 'processos'] {
      // Allow any authenticated user to read, write, create, and delete individual documents.
      allow get, create, update, delete: if isSignedIn();
      
      // Explicitly allow any authenticated user to list documents in these collections.
      allow list: if isSignedIn();
    }
  }
}
