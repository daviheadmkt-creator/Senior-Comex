rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para a coleção 'processos'
    match /processos/{docId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // Permite que qualquer usuário autenticado leia e escreva.
      allow read, write: if isSignedIn();
    }

    // Regra para a coleção 'users'
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isAdmin() {
        // Acesso ao documento do usuário para verificar a função 'funcao'
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Administrador';
      }
      
      // Um usuário pode ler seu próprio documento
      allow get: if isSignedIn() && isOwner(userId);
      
      // Apenas administradores podem listar todos os usuários
      allow list: if isSignedIn() && isAdmin();
      
      // Um usuário pode criar seu próprio documento se o ID for o mesmo do auth
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      
      // Um usuário pode atualizar seu próprio documento
      allow update: if isSignedIn() && isOwner(userId);
      
      // Um usuário pode deletar seu próprio documento
      allow delete: if isSignedIn() && isOwner(userId);
    }

    // Regra para a coleção 'partners'
    match /partners/{partnerId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // Qualquer usuário autenticado pode ler e escrever.
      allow read, write: if isSignedIn();
    }
  }
}
