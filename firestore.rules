/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports.
 * It provides open read access to partner information and restricts all access to authorized users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, accessible only to the owner.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs specific to a user, accessible only to the owner.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by a user, accessible only to the owner.
 * - /partners/{partnerId}: Stores partner information.
 *
 * Key Security Decisions:
 * - User listing is disallowed to prevent unauthorized access to user data.
 * - All write operations are protected by authorization checks.
 * - Data shape validation is relaxed for rapid prototyping.
 * - Timestamp fields are not validated to allow for maximum flexibility during prototyping.
 *
 * Denormalization for Authorization:
 * This ruleset uses path-based ownership to avoid the need for `get()` calls.
 * For example, audit logs are stored under the user's document, so the rules can directly check the path to verify ownership.
 * This ensures atomic operations and simpler debugging.
 *
 * Structural Segregation:
 * The separation of user-specific data (audit logs, reports) into subcollections under the user's document ensures that each collection has well-defined security requirements.
 * This prevents the need for complex filtering logic in the security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Grants access to user profiles based on ownership. Users can only read and modify their own profile.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Grants access to audit logs based on ownership. Users can only read and modify their own audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Grants access to reports based on ownership. Users can only read and modify their own reports.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Grants public read access to partner information, but restricts write access.
     */
    match /partners/{partnerId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add role based auth for creating partner documents if required
      allow update: if false; // TODO: Add role based auth for updating partner documents if required
      allow delete: if false; // TODO: Add role based auth for deleting partner documents if required
    }
  }
}