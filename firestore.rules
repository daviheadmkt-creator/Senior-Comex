/**
 * @file Firestore Security Rules for SeniorComex application.
 *
 * @corePhilosophy
 * This ruleset enforces a user-ownership model for user-specific data (profiles, audit logs, reports)
 * and allows authenticated users to read and write general data (partners, ports, terminals).
 * Access control is based on the authenticated user's identity (`request.auth.uid`).
 *
 * @dataStructure
 * - `/users/{userId}`: Stores user profile information.
 * - `/users/{userId}/auditLogs/{auditLogId}`: Stores audit logs specific to a user.
 * - `/users/{userId}/reports/{reportId}`: Stores reports generated by a user.
 * - `/partners/{partnerId}`: Stores partner information, accessible to all authenticated users.
 * - `/ports/{portId}`: Stores port information, accessible to all authenticated users.
 * - `/terminals/{terminalId}`: Stores terminal information, accessible to all authenticated users.
 *
 * @keySecurityDecisions
 * - Users can only create/modify their own profiles.
 * - Audit logs and reports are strictly user-owned and cannot be listed globally.
 * - Listing of the /users collection is denied, due to privacy concerns.
 * - Data types are NOT validated in this prototyping phase.
 *
 * @denormalizationForAuthorization
 * - The `userId` is embedded in the paths `/users/{userId}/auditLogs/{auditLogId}` and `/users/{userId}/reports/{reportId}` to enforce ownership without requiring `get()` calls.
 *
 * @structuralSegregation
 * - User-specific data (audit logs, reports) is stored in user subcollections to provide clear ownership and prevent accidental public exposure.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for user profiles. Users can only read and write their own profile.
     * @path /users/{userId}
     * @allow (create) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can create /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32
     * @allow (get) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can read /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32
     * @allow (update) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can update /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32
     * @allow (delete) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can delete /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32
     * @deny (create) - User ABC cannot create /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32
     * @deny (get) - User ABC cannot read /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces access control for audit logs. Only the owner user can create, read, update, or delete their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can create /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/auditLogs/someAuditLogId
     * @allow (get) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can read /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/auditLogs/someAuditLogId
     * @allow (update) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can update /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/auditLogs/someAuditLogId
     * @allow (delete) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can delete /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/auditLogs/someAuditLogId
     * @deny (create) - User ABC cannot create /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/auditLogs/someAuditLogId
     * @deny (get) - User ABC cannot read /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/auditLogs/someAuditLogId
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces access control for reports. Only the owner user can create, read, update, or delete their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can create /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/reports/someReportId
     * @allow (get) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can read /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/reports/someReportId
     * @allow (update) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can update /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/reports/someReportId
     * @allow (delete) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can delete /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/reports/someReportId
     * @deny (create) - User ABC cannot create /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/reports/someReportId
     * @deny (get) - User ABC cannot read /users/FJ4TWLjbvtdMx44fdAOTb4h8Ze32/reports/someReportId
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows all authenticated users to read and write partner information.
     * @path /partners/{partnerId}
     * @allow (create) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can create /partners/somePartnerId
     * @allow (get) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can read /partners/somePartnerId
     * @allow (update) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can update /partners/somePartnerId
     * @allow (delete) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can delete /partners/somePartnerId
     * @principle Allows public read and write access to partner information for authenticated users.
     */
    match /partners/{partnerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows all authenticated users to read and write port information.
     * @path /ports/{portId}
     * @allow (create) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can create /ports/somePortId
     * @allow (get) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can read /ports/somePortId
     * @allow (update) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can update /ports/somePortId
     * @allow (delete) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can delete /ports/somePortId
     * @principle Allows public read and write access to port information for authenticated users.
     */
    match /ports/{portId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows all authenticated users to read and write terminal information.
     * @path /terminals/{terminalId}
     * @allow (create) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can create /terminals/someTerminalId
     * @allow (get) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can read /terminals/someTerminalId
     * @allow (update) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can update /terminals/someTerminalId
     * @allow (delete) - User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can delete /terminals/someTerminalId
     * @principle Allows public read and write access to terminal information for authenticated users.
     */
    match /terminals/{terminalId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}