/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-related data (audit logs, reports),
 * with a separate collection for partners that has open read access for all users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, accessible only to the user themselves.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs, accessible only to the user.
 * - /users/{userId}/reports/{reportId}: Stores reports, accessible only to the user.
 * - /partners/{partnerId}: Stores partner data, with public read access and restricted write access.
 *
 * Key Security Decisions:
 * - Users can only access their own data (profile, audit logs, reports).
 * - User listing is disabled for privacy.
 * - Partner data is publicly readable but writable only with owner validation (TODO: Add owner field validation for `partners`).
 *
 * Denormalization for Authorization:
 * Path-based ownership is used for auditLogs and reports.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for user profiles.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their own profile.
     * @allow (get, update, delete) User with ID 'user123' can read, update, and delete their own profile.
     * @deny (get, update, delete) User with ID 'user456' cannot access user 'user123' profile.
     * @deny (create) User with ID 'user456' cannot create a profile with ID 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // User listing is not permitted.
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Enforces user-ownership for audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User with ID 'user123' can create an audit log for themselves.
     * @allow (get, update, delete) User with ID 'user123' can read, update, and delete their own audit logs.
     * @deny (get, update, delete) User with ID 'user456' cannot access user 'user123' audit logs.
     * @deny (create) User with ID 'user456' cannot create an audit log with ID 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Enforces user-ownership for reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User with ID 'user123' can create a report for themselves.
     * @allow (get, update, delete) User with ID 'user123' can read, update, and delete their own reports.
     * @deny (get, update, delete) User with ID 'user456' cannot access user 'user123' reports.
     * @deny (create) User with ID 'user456' cannot create a report with ID 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
        /**
     * @description Allows public read access to partners, but restricts write access to validated owners.
     * @path /partners/{partnerId}
     * @allow (get, list) Any user can read partner data.
     * @deny (create, update, delete) Unless the request is validated against owner.
     * @principle Public read access with owner-only writes.
     */
    match /partners/{partnerId} {
        function isSignedIn() {
          return request.auth != null;
        }

        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
        allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
        allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

      /**
       * @description Allows get access to the terminals.
       * @path /terminals
       * @allow (get) Any user can get access to the terminals.
       * @deny (list) Any user cannot list access to the terminals.
       * @principle Public read access with owner-only writes.
       */
      match /terminals/{terminalId} {
          function isSignedIn() {
            return request.auth != null;
          }

          allow get: if isSignedIn();
          allow list: if false; // Fixing the error reported.
          allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
          allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
          allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      }
  }
}