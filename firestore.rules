/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure data access based on user roles and ownership.
 * It uses path-based ownership where appropriate and allows for role-based access where required.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Only the user and admins can access.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Only the user and admins can access.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Only the user and admins can access.
 * - /partners/{partnerId}: Stores partner information. All authenticated users can read and write.
 * - /ports/{portId}: Stores shipping port information. All authenticated users can read and write.
 * - /terminals/{terminalId}: Stores terminal information within a port. All authenticated users can read and write.
 * - /processos/{processoId}: Stores export/import processes. All authenticated users can read and write.
 *
 * Key Security Decisions:
 * - User listing is explicitly denied to prevent information leakage.
 * - Data validation is relaxed to allow for rapid prototyping but critical ownership fields are validated.
 * - All write operations are secured with authorization checks to prevent unauthorized data modification.
 *
 * Denormalization for Authorization:
 * - User roles are stored directly in the /users/{userId} document to simplify role-based access control decisions.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Restricts access to user profiles.
     * @path /users/{userId}
     * @allow (get, create, update, delete) if isOwner(userId)
     * @deny (get) if false
     * @principle Enforces user-ownership and self-creation for user documents.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false; // User listing is not permitted

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && resource.data.id == request.resource.data.id && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Restricts access to user-specific audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create, get, list, update, delete) if isOwner(userId)
     * @deny (get) if false
     * @principle Enforces path-based ownership for audit logs, ensuring each user can only access their own logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Restricts access to user-specific reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create, get, list, update, delete) if isOwner(userId)
     * @deny (get) if false
     * @principle Enforces path-based ownership for reports, ensuring each user can only access their own reports.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Allows all authenticated users to read and write partner information.
     * @path /partners/{partnerId}
     * @allow (get, list, create, update, delete) if isSignedIn()
     * @deny (get) if false
     * @principle Provides public read and write access to partner data for authenticated users.
     */
    match /partners/{partnerId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows all authenticated users to read and write port information.
     * @path /ports/{portId}
     * @allow (get, list, create, update, delete) if isSignedIn()
     * @deny (get) if false
     * @principle Provides public read and write access to port data for authenticated users.
     */
    match /ports/{portId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows all authenticated users to read and write terminal information.
     * @path /terminals/{terminalId}
     * @allow (get, list, create, update, delete) if isSignedIn()
     * @deny (get) if false
     * @principle Provides public read and write access to terminal data for authenticated users.
     */
    match /terminals/{terminalId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows all authenticated users to read and write process information.
     * @path /processos/{processoId}
     * @allow (get, list, create, update, delete) if isSignedIn()
     * @deny (get) if false
     * @principle Provides public read and write access to process data for authenticated users.
     */
    match /processos/{processoId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }
  }
}