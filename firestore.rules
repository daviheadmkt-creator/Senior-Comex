/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a combination of user-ownership and role-based access control.
 * User profiles and their associated audit logs and reports are secured via path-based ownership,
 * ensuring only the owning user or an administrator can access them.
 * The partner collection allows any authenticated user to read and write.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Only the user and admins can read/write.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for a specific user. Only the user and admins can read/write.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by a specific user. Only the user and admins can read/write.
 * - /partners/{partnerId}: Stores partner information. All authenticated users can read/write.
 *
 * Key Security Decisions:
 * - Admin role is not yet implemented. Future iterations will allow admin roles to bypass user-ownership restrictions.
 * - User listing is restricted. Only admins should be able to list all users (not yet implemented).
 * - Partners collection is open to all authenticated users for read and write access.
 *
 * Denormalization for Authorization:
 * - User documents store the 'funcao' field (role) directly, avoiding the need for separate role lookups.
 *
 * Structural Segregation:
 * - Audit logs and reports are stored in user subcollections to provide clear ownership and avoid complex filtering.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure user profiles. Only the user themselves can read/write, and only they can create (with matching ID).
     * @path /users/{userId}
     * @allow (get, update, delete): User with UID userId
     * @allow (create): User with UID userId, provided the created document's 'id' field also matches userId.
     * @deny (get, update, delete): User with UID other than userId.
     * @deny (create): User with UID other than userId.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      // listing users is disabled in this prototype.  The original error occurred here.
      allow list: if false;

      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isSignedIn() && isOwner(userId) && resource.data.id == userId;
      allow delete: if isSignedIn() && isOwner(userId) && resource.data.id == userId;
    }

    /**
     * @description Secure audit logs for a specific user. Only the owning user can read/write.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get, list, update, delete): User with UID userId.
     * @allow (create): User with UID userId.
     * @deny (get, list, update, delete): User with UID other than userId.
     * @deny (create): User with UID other than userId.
     * @principle Restricts access to a user's own audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
       function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && resource != null;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

    /**
     * @description Secure reports generated by a specific user. Only the owning user can read/write.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get, list, update, delete): User with UID userId.
     * @allow (create): User with UID userId.
     * @deny (get, list, update, delete): User with UID other than userId.
     * @deny (create): User with UID other than userId.
     * @principle Restricts access to a user's own reports.
     */
    match /users/{userId}/reports/{reportId} {
       function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && resource != null;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

     /**
     * @description Allow any authenticated user to read and write partner information.
     * @path /partners/{partnerId}
     * @allow (get, list, create, update, delete): Any signed-in user.
     * @deny (get, list, create, update, delete): If not signed in.
     */
    match /partners/{partnerId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }
}