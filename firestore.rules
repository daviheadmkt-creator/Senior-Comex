rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuários só podem acessar seus próprios documentos
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Parceiros podem ser lidos e escritos por qualquer usuário autenticado
    match /partners/{partnerId} {
      allow read, write: if request.auth != null;
    }

    // Processos podem ser lidos e escritos por qualquer usuário autenticado
    match /processos/{processoId} {
      allow read, write: if request.auth != null;
    }
  }
}
