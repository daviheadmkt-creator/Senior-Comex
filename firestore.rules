/**
 * @file Firestore Security Rules for SeniorComex Application
 *
 * @core_philosophy This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports. Partners can be created by anyone, but only the creator can modify or delete them.
 *
 * @data_structure
 * - /users/{userId}: Stores user profile information. Each user can only access their own profile.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Only the user can access their own audit logs.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Only the user can access their own reports.
 * - /partners/{partnerId}: Stores partner information.
 *
 * @key_security_decisions
 * - Users can only read/write their own data. Listing all users is disallowed.
 * - Audit logs and reports are strictly owned by the user and nested under their profile.
 * - Partners can be created by anyone and there is currently no restriction on who can list partners.
 *
 * @denormalization_for_authorization Path-based ownership is used for `auditLogs` and `reports` collections to relate them to users.
 *
 * @structural_segregation User-specific data (auditLogs, reports) is stored in subcollections under the user's document for better security and performance.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for user profiles.
     * @path /users/{userId}
     * @allow (get) Authenticated user can read their own profile data.
     * @allow (create) Authenticated user can create their own profile data if the userId matches their auth UID.
     * @allow (update) Authenticated user can update their own profile data if the userId matches their auth UID and the document exists.
     * @allow (delete) Authenticated user can delete their own profile data if the userId matches their auth UID and the document exists.
     * @deny (get) Authenticated user cannot read another user's profile data.
     * @deny (list) No one can list all users.
     * @deny (create) Authenticated user cannot create a profile with a different userId.
     * @deny (update) Authenticated user cannot update another user's profile data.
     * @deny (delete) Authenticated user cannot delete another user's profile data.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // Disallow listing all users

      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get) Authenticated user can read their own audit logs.
     * @allow (create) Authenticated user can create their own audit logs if the userId matches their auth UID.
     * @allow (update) Authenticated user can update their own audit logs if the userId matches their auth UID and the document exists.
     * @allow (delete) Authenticated user can delete their own audit logs if the userId matches their auth UID and the document exists.
     * @deny (get) Authenticated user cannot read another user's audit logs.
     * @deny (list) Authenticated user cannot list another user's audit logs.
     * @deny (create) Authenticated user cannot create audit logs for another user.
     * @deny (update) Authenticated user cannot update another user's audit logs.
     * @deny (delete) Authenticated user cannot delete another user's audit logs.
     * @principle Enforces document ownership for all operations, using path-based ownership.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);

      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get) Authenticated user can read their own reports.
     * @allow (create) Authenticated user can create their own reports if the userId matches their auth UID.
     * @allow (update) Authenticated user can update their own reports if the userId matches their auth UID and the document exists.
     * @allow (delete) Authenticated user can delete their own reports if the userId matches their auth UID and the document exists.
     * @deny (get) Authenticated user cannot read another user's reports.
     * @deny (list) Authenticated user cannot list another user's reports.
     * @deny (create) Authenticated user cannot create reports for another user.
     * @deny (update) Authenticated user cannot update another user's reports.
     * @deny (delete) Authenticated user cannot delete another user's reports.
     * @principle Enforces document ownership for all operations, using path-based ownership.
     */
    match /users/{userId}/reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);

      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

       /**
     * @description Allows anyone to read and create partners, but only the owner can update or delete.
     * @path /partners/{partnerId}
     * @allow (get) Anyone can read partner data.
     * @allow (list) Anyone can list all partners.
     * @allow (create) Anyone can create partner data.
     * @deny (update) Only the owner of the partner document can update it.
     * @deny (delete) Only the owner of the partner document can delete it.
     * @principle Owner-only writes with public reads.
     */
    match /partners/{partnerId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // NOTE: Because the Partner entity does not have an ownership field, we cannot implement owner-only writes.

      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn();
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }
}