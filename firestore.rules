/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports. 
 * All user-related data is nested under the /users/{userId} path. Partners are accessible by any authenticated user.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only to the user themselves.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs related to a specific user, accessible only to that user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by a specific user, accessible only to that user.
 * - /partners/{partnerId}: Stores partner information, accessible to any authenticated user.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect user privacy.
 * - Read-only access to public collections is handled via `allow get, list: if true`.
 * - All write operations are strictly controlled based on user ownership.
 *
 * Denormalization for Authorization:
 *  - AuditLog and Report documents are related to users using path-based ownership (`/users/{userId}/auditLogs/{auditLogId}` and `/users/{userId}/reports/{reportId}`).
 *  This approach avoids the need for `get()` calls to retrieve parent document data during authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the /users/{userId} collection, ensuring only the user can access their own profile.
     * @path /users/{userId}
     * @allow (get, create, update, delete) User with ID "in34VaH79wdKPVFlnFsbwtbRbUr2" can (get, create, update, delete) their own profile at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @deny (get, create, update, delete) User with ID "in34VaH79wdKPVFlnFsbwtbRbUr2" cannot (get, create, update, delete) the profile of another user at /users/someOtherUserId.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      // Only the user can read their own profile.
      allow get: if isOwner(userId);

      // Only the user can create their own profile. The document ID must match their user ID.
      allow create: if isOwner(userId) && request.resource.data.id == userId;

      // Only the user can update their own profile. The user ID in the path must match the user ID in the existing document.
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;

      // Only the user can delete their own profile.
      allow delete: if isExistingOwner(userId);

      // User listing is not allowed.
      allow list: if false;
    }

    /**
     * @description Secures the /users/{userId}/auditLogs/{auditLogId} collection, ensuring only the user can access their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get, list, create, update, delete) User with ID "in34VaH79wdKPVFlnFsbwtbRbUr2" can (get, list, create, update, delete) audit logs under /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/{auditLogId}.
     * @deny (get, list, create, update, delete) User with ID "in34VaH79wdKPVFlnFsbwtbRbUr2" cannot (get, list, create, update, delete) audit logs under /users/someOtherUserId/auditLogs/{auditLogId}.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      // Only the owner can read their audit logs.
      allow get: if isOwner(userId);

      // Only the owner can list their audit logs.
      allow list: if isOwner(userId);

      // Only the owner can create audit logs.
      allow create: if isOwner(userId);

      // Only the owner can update their audit logs.
      allow update: if isExistingOwner(userId);

      // Only the owner can delete their audit logs.
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures the /users/{userId}/reports/{reportId} collection, ensuring only the user can access their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get, list, create, update, delete) User with ID "in34VaH79wdKPVFlnFsbwtbRbUr2" can (get, list, create, update, delete) reports under /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/{reportId}.
     * @deny (get, list, create, update, delete) User with ID "in34VaH79wdKPVFlnFsbwtbRbUr2" cannot (get, list, create, update, delete) reports under /users/someOtherUserId/reports/{reportId}.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/reports/{reportId} {
      // Only the owner can read their reports.
      allow get: if isOwner(userId);

      // Only the owner can list their reports.
      allow list: if isOwner(userId);

      // Only the owner can create reports.
      allow create: if isOwner(userId);

      // Only the owner can update their reports.
      allow update: if isExistingOwner(userId);

      // Only the owner can delete their reports.
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows any authenticated user to read partner information.
     * @path /partners/{partnerId}
     * @allow (get, list) Any authenticated user can (get, list) partner information.
     * @allow (create) Any authenticated user can create a partner.
     * @allow (update, delete) No one can update or delete a partner. // TODO: Add owner validation once the schema is updated with an ownership field.
     * @deny (get, list) Unauthenticated users cannot (get, list) partner information.
     * @principle Allows public read access to partner data while restricting write access to authenticated users.
     */
    match /partners/{partnerId} {
      // Anyone can read partners.
      allow get, list: if isSignedIn();

      // Anyone signed in can create a new partner.
      allow create: if isSignedIn();

      // No one can update or delete partner information.
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }

  // Helper function to determine if the user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to determine if the user is the owner of the resource.
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  // Helper function to determine if the user is the owner of the resource and the resource exists.
  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}