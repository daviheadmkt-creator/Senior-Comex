/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports,
 *              while providing public read access to partner information.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only to the owning user.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs, accessible only to the owning user.
 * - /users/{userId}/reports/{reportId}: Stores reports, accessible only to the owning user.
 * - /partners/{partnerId}: Stores partner information, publicly readable.
 *
 * Key Security Decisions:
 * - User listing is disabled for privacy.
 * - Audit logs and reports are strictly user-owned, enforced via path-based ownership.
 * - Partner data is publicly readable, but write access is not yet defined (TODO).
 * - Data validation is minimal in this prototyping phase, focusing on authorization.
 *
 * Denormalization for Authorization:
 * - The userID is present in paths to allow for easier authorization with "isOwner()".
 *
 * Structural Segregation:
 * - Private user data (profiles, logs, reports) is segregated under /users/{userId} to simplify access control and prevent accidental exposure.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures user profile information.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their own profile.
     * @deny (create) User with ID 'user456' cannot create a profile for 'user123'.
     * @allow (get) User with ID 'user123' can read their own profile.
     * @deny (get) User with ID 'user456' cannot read the profile of 'user123'.
     * @allow (update) User with ID 'user123' can update their own profile.
     * @deny (update) User with ID 'user456' cannot update the profile of 'user123'.
     * @allow (delete) User with ID 'user123' can delete their own profile.
     * @deny (delete) User with ID 'user456' cannot delete the profile of 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false; // User listing is disabled for privacy.
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Secures audit logs for each user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User 'user123' can create audit logs under their profile.
     * @deny (create) User 'user456' cannot create audit logs under 'user123' profile.
     * @allow (get) User 'user123' can read audit logs under their profile.
     * @deny (get) User 'user456' cannot read audit logs under 'user123' profile.
     * @allow (update) User 'user123' can update audit logs under their profile.
     * @deny (update) User 'user456' cannot update audit logs under 'user123' profile.
     * @allow (delete) User 'user123' can delete audit logs under their profile.
     * @deny (delete) User 'user456' cannot delete audit logs under 'user123' profile.
     * @principle Enforces path-based ownership: all audit logs belong to the user specified in the path.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Secures reports generated by each user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User 'user123' can create reports under their profile.
     * @deny (create) User 'user456' cannot create reports under 'user123' profile.
     * @allow (get) User 'user123' can read reports under their profile.
     * @deny (get) User 'user456' cannot read reports under 'user123' profile.
     * @allow (update) User 'user123' can update reports under their profile.
     * @deny (update) User 'user456' cannot update reports under 'user123' profile.
     * @allow (delete) User 'user123' can delete reports under their profile.
     * @deny (delete) User 'user456' cannot delete reports under 'user123' profile.
     * @principle Enforces path-based ownership: all reports belong to the user specified in the path.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

     /**
     * @description Secures partner information (publicly readable).
     * @path /partners/{partnerId}
     * @allow (get) Any user can read partner information.
     * @allow (list) Any user can list partner information.
     * @deny (create) No one can create partner documents without proper authorization. // TODO: Define proper authorization
     * @deny (update) No one can update partner documents without proper authorization. // TODO: Define proper authorization
     * @deny (delete) No one can delete partner documents without proper authorization. // TODO: Define proper authorization
     * @principle Provides public read access to partner data, with restricted write access.
     */
    match /partners/{partnerId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }
}