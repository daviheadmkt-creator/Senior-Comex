/**
 * @file Firestore Security Rules for SeniorComex application.
 *
 * @core_philosophy This ruleset enforces a strict user-ownership model for user-related data (audit logs, reports),
 *                  and role-based access control for listing users. It leverages path-based ownership to simplify
 *                  security rules and enable atomic operations.
 *
 * @data_structure Data is organized hierarchically. User profiles are stored under `/users/{userId}`.
 *                 Audit logs and reports are stored as subcollections under each user document
 *                 (`/users/{userId}/auditLogs/{auditLogId}` and `/users/{userId}/reports/{reportId}`).
 *                 Partner data is stored in `/partners/{partnerId}`.
 *
 * @key_security_decisions
 *   - Listing users requires administrator privileges (`funcao == 'Administrador'`).
 *   - User's can only manage their own auditLogs and reports.
 *   - Partner data can be accessed by any authenticated user.
 *
 * @denormalization_for_authorization
 *   - The user's role (`funcao`) is stored directly in the user document to avoid extra `get()` calls
 *     when checking for administrator privileges.
 *
 * @structural_segregation
 *   - User-specific data (audit logs, reports) is stored in private subcollections under the user's document,
 *     ensuring that only the user (or an admin) can access it.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /processos/{processoId} {
      allow read, write: if request.auth != null;
    }

    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isAdmin() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Administrador';
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isSignedIn() && isOwner(userId) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

    match /users/{userId}/auditLogs/{auditLogId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && resource != null;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

    match /users/{userId}/reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && resource != null;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }
    /**
     * @description Allows reading and writing partner data. Any authenticated user can read or write partner data.
     * @path /partners/{partnerId}
     * @allow (create) Any authenticated user can create a partner.
     * @allow (get) Any authenticated user can read a partner.
     * @allow (update) Any authenticated user can update a partner.
     * @allow (delete) Any authenticated user can delete a partner.
     * @principle Allows any authenticated user to read or write partner data.
     */
     match /partners/{partnerId} {
        function isSignedIn() {
          return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
     }
  }
}
