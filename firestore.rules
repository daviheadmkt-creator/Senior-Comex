/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-related data (audit logs, reports),
 * and allows open read access to partners data. All write operations require authentication.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user.
 * - /partners/{partnerId}: Stores partner information.
 *
 * Key Security Decisions:
 * - Users can only manage their own profiles, audit logs, and reports.
 * - Listing of user documents is disallowed to prevent information disclosure.
 * - Partner data is publicly readable.
 *
 * Denormalization for Authorization:
 * - User-related data is nested under the respective user's document to ensure that all authorization checks are based on the path,
 *   eliminating the need for additional reads to verify ownership.
 *
 * Structural Segregation:
 * - User-specific data (auditLogs, reports) is stored in subcollections under the /users/{userId} path,
 *   providing a clear separation between user data and other data types, and enabling granular access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Prevents listing of all user documents.
     * @path /users
     * @allow None - Listing users is disallowed.
     * @deny list: if true;
     * @principle Prevents information disclosure by disallowing user enumeration.
     */
    match /users {
        allow get: if false;
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Allows a user to read, create, update, and delete their own user document.
     * @path /users/{userId}
     * @allow (get) User with ID 'user123' can read their own profile.
     * @allow (create) User with ID 'user123' can create their own profile.
     * @allow (update) User with ID 'user123' can update their own profile.
     * @allow (delete) User with ID 'user123' can delete their own profile.
     * @deny (get) User with ID 'user456' cannot read user 'user123' profile.
     * @deny (create) User with ID 'user456' cannot create user 'user123' profile.
     * @deny (update) User with ID 'user456' cannot update user 'user123' profile.
     * @deny (delete) User with ID 'user456' cannot delete user 'user123' profile.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows a user to read, create, update, and delete their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get) User with ID 'user123' can read their own audit log 'auditLog456'.
     * @allow (create) User with ID 'user123' can create their own audit log 'auditLog456'.
     * @allow (update) User with ID 'user123' can update their own audit log 'auditLog456'.
     * @allow (delete) User with ID 'user123' can delete their own audit log 'auditLog456'.
     * @deny (get) User with ID 'user456' cannot read audit log 'auditLog456' under user 'user123'.
     * @deny (create) User with ID 'user456' cannot create audit log 'auditLog456' under user 'user123'.
     * @deny (update) User with ID 'user456' cannot update audit log 'auditLog456' under user 'user123'.
     * @deny (delete) User with ID 'user456' cannot delete audit log 'auditLog456' under user 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
       function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows a user to read, create, update, and delete their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get) User with ID 'user123' can read their own report 'report456'.
     * @allow (create) User with ID 'user123' can create their own report 'report456'.
     * @allow (update) User with ID 'user123' can update their own report 'report456'.
     * @allow (delete) User with ID 'user123' can delete their own report 'report456'.
     * @deny (get) User with ID 'user456' cannot read report 'report456' under user 'user123'.
     * @deny (create) User with ID 'user456' cannot create report 'report456' under user 'user123'.
     * @deny (update) User with ID 'user456' cannot update report 'report456' under user 'user123'.
     * @deny (delete) User with ID 'user456' cannot delete report 'report456' under user 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
       function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

     /**
      * @description Allows public read access to partner data, but requires authentication for write access.
      * @path /partners/{partnerId}
      * @allow (get, list) Any user can read partner data.
      * @allow (create) Any authenticated user can create partner data.
      * @allow (update) Any authenticated user can update partner data.
      * @allow (delete) Any authenticated user can delete partner data.
      * @deny (create) Non-authenticated user cannot create partner data.
      * @deny (update) Non-authenticated user cannot update partner data.
      * @deny (delete) Non-authenticated user cannot delete partner data.
      * @principle Allows public read access but requires authentication for writes.
      */
    match /partners/{partnerId} {
        function isSignedIn() {
            return request.auth != null;
        }
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

     /**
      * @description The error message indicates a permission error when listing documents in the 'processos' collection.
      *              Since there is no explicit rule for the 'processos' collection, it is implicitly denied.  Adding this
      *              stub deny rule here to ensure the error encountered previously is handled and to explicitly prevent
      *              listing of this collection until it is properly defined/configured.
      * @path /processos
      * @allow none
      * @deny list: if true;
      * @principle Explicitly deny access to undefined collections.
      */
     match /processos {
        allow get: if false;
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }
  }
}