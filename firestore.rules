/**
 * @fileOverview
 * This ruleset enforces a strict user-ownership model for user-related data (profiles, audit logs, and reports)
 * and allows only authenticated users to manage partner information.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, accessible only to the user themselves.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs specific to a user, accessible only to that user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by a user, accessible only to that user.
 * - /partners/{partnerId}: Stores partner information, accessible only to authenticated users.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Audit logs and reports are secured via path-based ownership, avoiding extra reads.
 * - Partner information can be created, updated, or deleted by any authenticated user.
 *
 * Denormalization for Authorization:
 * - User-specific data (audit logs, reports) is nested under the /users/{userId} path. This allows authorization based solely on the path, avoiding the need to duplicate user IDs within the document itself.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures user profiles.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their own profile.
     * @allow (get) User with ID 'user123' can read their own profile.
     * @allow (update) User with ID 'user123' can update their own profile.
     * @allow (delete) User with ID 'user123' can delete their own profile.
     * @deny (create) User with ID 'user123' cannot create a profile for 'user456'.
     * @deny (get) User with ID 'user123' cannot read the profile of 'user456'.
     * @deny (update) User with ID 'user123' cannot update the profile of 'user456'.
     * @deny (delete) User with ID 'user123' cannot delete the profile of 'user456'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource.data.id == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures audit logs for each user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User with ID 'user123' can create an audit log for themselves.
     * @allow (get) User with ID 'user123' can read their own audit logs.
     * @allow (update) User with ID 'user123' can update their own audit logs.
     * @allow (delete) User with ID 'user123' can delete their own audit logs.
     * @deny (create) User with ID 'user123' cannot create an audit log for 'user456'.
     * @deny (get) User with ID 'user123' cannot read audit logs for 'user456'.
     * @deny (update) User with ID 'user123' cannot update audit logs for 'user456'.
     * @deny (delete) User with ID 'user123' cannot delete audit logs for 'user456'.
     * @principle Restricts access to a user's own audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures reports generated by each user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User with ID 'user123' can create a report for themselves.
     * @allow (get) User with ID 'user123' can read their own reports.
     * @allow (update) User with ID 'user123' can update their own reports.
     * @allow (delete) User with ID 'user123' can delete their own reports.
     * @deny (create) User with ID 'user123' cannot create a report for 'user456'.
     * @deny (get) User with ID 'user123' cannot read reports for 'user456'.
     * @deny (update) User with ID 'user123' cannot update reports for 'user456'.
     * @deny (delete) User with ID 'user123' cannot delete reports for 'user456'.
     * @principle Restricts access to a user's own reports.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures partner information.
     * @path /partners/{partnerId}
     * @allow (create) Authenticated user can create a partner.
     * @allow (get) All users can read partner information.
     * @allow (list) All users can list partners.
     * @allow (update) Authenticated user can update a partner.
     * @allow (delete) Authenticated user can delete a partner.
     * @deny (create) Unauthenticated user cannot create a partner.
     * @deny (update) Unauthenticated user cannot update a partner.
     * @deny (delete) Unauthenticated user cannot delete a partner.
     * @principle Allows authenticated users to manage partner information.
     */
    match /partners/{partnerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

   }

  /**
   * @description Checks if the user is signed in.
   * @return {boolean} True if the user is signed in, false otherwise.
   */
  function isSignedIn() {
    return request.auth != null;
  }

  /**
   * @description Checks if the requested user ID matches the authenticated user's ID.
   * @param {string} userId The user ID to check.
   * @return {boolean} True if the user IDs match, false otherwise.
   */
  function isOwner(userId) {
    return isSignedIn() && request.auth.uid == userId;
  }

    /**
   * @description Checks if the requested user ID matches the authenticated user's ID and that resource exists.
   * @param {string} userId The user ID to check.
   * @return {boolean} True if the user IDs match, false otherwise.
   */
  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}