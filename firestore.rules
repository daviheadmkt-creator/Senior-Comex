/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user-specific data,
 * with public read access to the `ports` collection.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Only the user and admins can access.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Only the user can access.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Only the user can access.
 * - /partners/{partnerId}: Stores partner information. All authenticated users can read and write to this collection.
 * - /ports/{portId}: Stores port information. Intended for public read access.
 * - /terminals/{terminalId}: Stores terminal information. Intended for public read access.
 *
 * Key Security Decisions:
 * - User data is private and only accessible by the user and administrators.
 * - Audit logs and reports are owned by the user and only accessible by that user.
 * - The `ports` collection is publicly readable.
 * - The `terminals` collection is publicly readable.
 * - Write operations on any collection require a valid, authenticated user.
 * - No user listing is allowed (to protect user privacy).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by an authenticated user.
     * @path N/A (Helper function)
     * @allow N/A (Helper function)
     * @deny N/A (Helper function)
     * @principle Requires a valid Firebase Authentication token for access.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided user ID.
     * @path N/A (Helper function)
     * @allow N/A (Helper function)
     * @deny N/A (Helper function)
     * @principle Enforces user-ownership.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided user ID and resource exists
     * @path N/A (Helper function)
     * @allow N/A (Helper function)
     * @deny N/A (Helper function)
     * @principle Enforces user-ownership and that resource exists for destructive operations.
     */
    function isExistingOwner(userId) {
      return (isOwner(userId) && resource != null);
    }

    /**
     * @description Defines security rules for user profiles.
     * @path /users/{userId}
     * @allow (create) If the user is creating their own profile (request.auth.uid == userId).
     * @allow (get) If the user is requesting their own profile (request.auth.uid == userId).
     * @deny (create) If the user is trying to create a profile with a different userId.
     * @deny (update, delete) If the user is not the owner.
     * @principle Enforces document ownership for writes and restricts read access to the owner.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;
    }

    /**
     * @description Defines security rules for audit logs, nested under users.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) If the user is creating an audit log for themselves (request.auth.uid == userId).
     * @allow (get, list) If the user is requesting their own audit logs (request.auth.uid == userId).
     * @deny (create) If the user is trying to create an audit log for a different userId.
     * @deny (update, delete) If the user is not the owner.
     * @principle Enforces document ownership for writes and restricts read access to the owner.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Defines security rules for reports, nested under users.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) If the user is creating a report for themselves (request.auth.uid == userId).
     * @allow (get, list) If the user is requesting their own reports (request.auth.uid == userId).
     * @deny (create) If the user is trying to create a report for a different userId.
     * @deny (update, delete) If the user is not the owner.
     * @principle Enforces document ownership for writes and restricts read access to the owner.
     */
    match /users/{userId}/reports/{reportId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
    
    /**
     * @description Defines security rules for partners. All authenticated users can read and write.
     * @path /partners/{partnerId}
     * @allow (get, list) If the user is authenticated.
     * @allow (create, update, delete) If the user is authenticated.
     * @principle Allows any authenticated user to manage partner data.
     */
    match /partners/{partnerId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Defines security rules for ports. Public read, authenticated write.
     * @path /ports/{portId}
     * @allow (get, list) Public read access.
     * @allow (create, update, delete) If the user is authenticated.
     */
    match /ports/{portId} {
        allow get, list: if true;
        allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Defines security rules for terminals. Public read, authenticated write.
     * @path /terminals/{terminalId}
     * @allow (get, list) Public read access.
     * @allow (create, update, delete) If the user is authenticated.
     */
    match /terminals/{terminalId} {
        allow get, list: if true;
        allow create, update, delete: if isSignedIn();
    }
  }
}