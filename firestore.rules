
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().funcao == 'Administrador';
    }

    match /users/{userId} {
      // Allow user to read their own document
      allow get: if isOwner(userId) || isAdmin();
      // Allow admin to list all users
      allow list: if isAdmin();
      // Allow user to create their own document
      allow create: if isOwner(userId);
      // Allow user to update their own document or admin to update any
      allow update: if isOwner(userId) || isAdmin();
      // Allow admin to delete users
      allow delete: if isAdmin();
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /partners/{partnerId} {
      allow read, write: if isSignedIn();
    }

    match /ports/{portId} {
        allow read, write: if isSignedIn();
    }

    match /terminals/{terminalId} {
        allow read, write: if isSignedIn();
    }

    match /processos/{processoId} {
      allow read, write: if isSignedIn();
    }
  }
}
