/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a combination of user-ownership and role-based access control.
 * User-specific data (audit logs, reports) is nested under /users/{userId} and secured using path-based ownership.
 * Other collections (partners, ports, terminals, processos) are accessible to all authenticated users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user.
 * - /partners/{partnerId}: Stores partner information.
 * - /ports/{portId}: Stores port information.
 * - /terminals/{terminalId}: Stores terminal information.
 * - /processos/{processoId}: Stores export/import process information.
 *
 * Key Security Decisions:
 * - User listing is explicitly denied to all users.
 * - Path-based ownership is used for audit logs and reports to ensure Authorization Independence and avoid get() calls in rules.
 * - All authenticated users can manage partners, ports, terminals, and processos.
 *
 * Denormalization for Authorization:
 * - Not explicitly used, as the data structure leverages path-based ownership for user-specific data.
 *
 * Structural Segregation:
 * - Private user data (audit logs, reports) is segregated under the /users/{userId} path, while other data is stored in top-level collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing document.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /users collection.
     * @path /users/{userId}
     * @allow (create) User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can create their own profile document.
     * @deny (create) User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" cannot create a profile for another user.
     * @allow (get) User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can read their own profile.
     * @deny (get) User "randomUserId" cannot read User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32"'s profile.
     * @principle Enforces user-ownership for profile access and creation.
     */
    match /users/{userId} {
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow get: if isOwner(userId);
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
      allow list: if false; // User listing is not allowed
    }

    /**
     * @description Rules for the /users/{userId}/auditLogs collection.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can create audit logs under their profile.
     * @deny (create) User "randomUserId" cannot create audit logs under User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32"'s profile.
     * @allow (get) User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can read their own audit logs.
     * @deny (get) User "randomUserId" cannot read User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32"'s audit logs.
     * @principle Enforces user-ownership for audit log access.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow create: if isOwner(userId);
      allow get: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
      allow list: if isOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/reports collection.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can create reports under their profile.
     * @deny (create) User "randomUserId" cannot create reports under User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32"'s profile.
     * @allow (get) User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can read their own reports.
     * @deny (get) User "randomUserId" cannot read User "FJ4TWLjbvtdMx44fdAOTb4h8Ze32"'s reports.
     * @principle Enforces user-ownership for report access.
     */
    match /users/{userId}/reports/{reportId} {
      allow create: if isOwner(userId);
      allow get: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
      allow list: if isOwner(userId);
    }

    /**
     * @description Rules for the /partners collection.
     * @path /partners/{partnerId}
     * @allow (create) Any authenticated user can create a partner.
     * @allow (get) Any authenticated user can read a partner.
     * @principle Allows any authenticated user to manage partners.
     */
    match /partners/{partnerId} {
        allow create: if isSignedIn();
        allow get: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
        allow list: if isSignedIn();
    }

    /**
     * @description Rules for the /ports collection.
     * @path /ports/{portId}
     * @allow (create) Any authenticated user can create a port.
     * @allow (get) Any authenticated user can read a port.
     * @principle Allows any authenticated user to manage ports.
     */
    match /ports/{portId} {
        allow create: if isSignedIn();
        allow get: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
        allow list: if isSignedIn();
    }

    /**
     * @description Rules for the /terminals collection.
     * @path /terminals/{terminalId}
     * @allow (create) Any authenticated user can create a terminal.
     * @allow (get) Any authenticated user can read a terminal.
     * @principle Allows any authenticated user to manage terminals.
     */
    match /terminals/{terminalId} {
        allow create: if isSignedIn();
        allow get: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
        allow list: if isSignedIn();
    }

    /**
     * @description Rules for the /processos collection.
     * @path /processos/{processoId}
     * @allow (create) Any authenticated user can create a processo.
     * @allow (get) Any authenticated user can read a processo.
     * @principle Allows any authenticated user to manage processos.
     */
    match /processos/{processoId} {
        allow create: if isSignedIn();
        allow get: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
        allow list: if isSignedIn();
    }
  }
}