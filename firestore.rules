rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /processos/{docId} {
      allow list, get, create, update, delete: if request.auth != null;
    }

    match /partners/{partnerId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list, create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isAdmin() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Administrador';
      }
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isSignedIn() && isOwner(userId) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}
