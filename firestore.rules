/**
 * @file Firestore Security Rules for SeniorComex Application
 * @core_philosophy This ruleset enforces a strict user-ownership model for user-specific data (audit logs, reports)
 *   and allows authenticated access to other collections (partners, ports, terminals, processes).
 * @data_structure
 *   - /users/{userId}: Stores user profiles. Only the user and admins can access.
 *   - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Only the user can access.
 *   - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Only the user can access.
 *   - /partners/{partnerId}: Stores partner information. All authenticated users can read and write.
 *   - /ports/{portId}: Stores port information. All authenticated users can read and write.
 *   - /terminals/{terminalId}: Stores terminal information. All authenticated users can read and write.
 *   - /processos/{processoId}: Stores export/import processes. All authenticated users can read, create, update and delete.
 * @key_security_decisions
 *   - User listing is explicitly denied to prevent information disclosure.
 *   - All write operations (create, update, delete) require user authentication.
 *   - Flexible data shapes: the rules do not impose a rigid schema for the data being written.
 * @denormalization_for_authorization The data structure uses path-based ownership for auditLogs and reports,
 *   avoiding the need for additional reads during authorization.
 * @structural_segregation User-specific data (auditLogs and reports) is stored in user subcollections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by a signed-in user.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the request is made by the owner of the resource.
     * @param {string} userId The user ID to check against.
     * @return {bool} True if the user ID matches the authenticated user's ID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the request is made by the existing owner of the resource.
     * @param {string} userId The user ID to check against.
     * @return {bool} True if the user ID matches the authenticated user's ID and the resource exists.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /users/{userId} collection.
     * @path /users/{userId}
     * @allow (get) Signed-in user can read their own profile.
     * @allow (create) Signed-in user can create their own profile.
     * @deny (list) Listing all users is denied.
     * @deny (update) Another user cannot update someone elses user profile
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/auditLogs/{auditLogId} collection.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User can create audit logs under their own user ID.
     * @allow (get) User can read their own audit logs.
     * @deny (update) User cannot update other users audit logs.
     * @deny (delete) User cannot delete other users audit logs.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/reports/{reportId} collection.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User can create reports under their own user ID.
     * @allow (get) User can read their own reports.
     * @deny (update) User cannot update other users reports.
     * @deny (delete) User cannot delete other users reports.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.generatedByUserId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.generatedByUserId == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /partners/{partnerId} collection.
     * @path /partners/{partnerId}
     * @allow (get) All authenticated users can read partner data.
     * @allow (create) All authenticated users can create partner data.
     * @allow (update) All authenticated users can update partner data.
     * @allow (delete) All authenticated users can delete partner data.
     * @principle Allows authenticated access to partner data.
     */
    match /partners/{partnerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Rules for the /ports/{portId} collection.
     * @path /ports/{portId}
     * @allow (get) All authenticated users can read port data.
     * @allow (create) All authenticated users can create port data.
     * @allow (update) All authenticated users can update port data.
     * @allow (delete) All authenticated users can delete port data.
     */
    match /ports/{portId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Rules for the /terminals/{terminalId} collection.
     * @path /terminals/{terminalId}
     * @allow (get) All authenticated users can read terminal data.
     * @allow (create) All authenticated users can create terminal data.
     * @allow (update) All authenticated users can update terminal data.
     * @allow (delete) All authenticated users can delete terminal data.
     */
    match /terminals/{terminalId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Rules for the /processos/{processoId} collection.
     * @path /processos/{processoId}
     * @allow (get) All authenticated users can read a process.
     * @allow (create) All authenticated users can create a process.
     * @allow (update) All authenticated users can update a process.
     * @allow (delete) All authenticated users can delete a process.
     */
    match /processos/{processoId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }
}