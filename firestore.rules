rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /partners/{partnerId} {
      allow read, write: if request.auth != null;
    }
    
    match /processos/{processoId} {
        allow read, write: if request.auth != null;
    }

    match /products/{productId} {
      // Allow authenticated users to get a single document
      allow get: if request.auth != null;
      // Allow authenticated users to create, update, delete documents
      allow write: if request.auth != null;
    }

    // Explicitly allow listing the entire collection for authenticated users
    match /products {
      allow list: if request.auth != null;
    }
  }
}
