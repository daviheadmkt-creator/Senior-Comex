/**
 * @file Firestore Security Rules for SeniorComex application.
 * @core_philosophy This ruleset enforces a strict user-ownership model for user-specific data (audit logs, reports),
 *   with separate top-level collections for user profiles and partners.
 * @data_structure
 *   - `/users/{userId}`: Stores user profile information.
 *   - `/users/{userId}/auditLogs/{auditLogId}`: Stores audit logs specific to a user.
 *   - `/users/{userId}/reports/{reportId}`: Stores reports generated by a user.
 *   - `/partners/{partnerId}`: Stores partner information.
 * @key_security_decisions
 *   - User profiles (`/users/{userId}`) are readable only by the authenticated user.
 *   - Listing the `/users` collection is denied to prevent unauthorized access to user information.
 *   - Audit logs and reports are accessible only to the user to whom they belong.
 *   - Partner data is currently open to read and write. Consider further restrictions for production.
 * @denormalization_for_authorization
 *   - Audit logs and reports are stored as subcollections under the user document to simplify authorization checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the user profiles collection. Only the authenticated user can read/write their own profile. Listing all users is denied.
     * @path /users/{userId}
     * @allow (get) User with UID 'userId' can read their own profile.
     * @deny (get) User with UID 'otherUserId' cannot read user profile at /users/{userId}.
     * @allow (create) User with UID 'userId' can create their own profile.
     * @deny (create) User with UID 'otherUserId' cannot create a profile at /users/{userId}.
     * @allow (update) User with UID 'userId' can update their own profile.
     * @deny (update) User with UID 'otherUserId' cannot update user profile at /users/{userId}.
     * @allow (delete) User with UID 'userId' can delete their own profile.
     * @deny (delete) User with UID 'otherUserId' cannot delete user profile at /users/{userId}.
     * @principle Enforces document ownership for writes and restricts reads to the owner.  Also prevents listing of all users.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false; // Prevent listing all users

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && resource.data.id == userId; // Enforce immutability of userId
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Secures the audit logs subcollection. Only the owner user can read/write their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get) User with UID 'userId' can read their audit log.
     * @deny (get) User with UID 'otherUserId' cannot read the audit log at /users/{userId}/auditLogs/{auditLogId}.
     * @allow (create) User with UID 'userId' can create an audit log.
     * @deny (create) User with UID 'otherUserId' cannot create an audit log at /users/{userId}/auditLogs/{auditLogId}.
     * @allow (update) User with UID 'userId' can update their own audit log.
     * @deny (update) User with UID 'otherUserId' cannot update audit log at /users/{userId}/auditLogs/{auditLogId}.
     * @allow (delete) User with UID 'userId' can delete their own audit log.
     * @deny (delete) User with UID 'otherUserId' cannot delete audit log at /users/{userId}/auditLogs/{auditLogId}.
     * @principle Enforces path-based ownership for all operations on audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Secures the reports subcollection. Only the owner user can read/write their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get) User with UID 'userId' can read their report.
     * @deny (get) User with UID 'otherUserId' cannot read report at /users/{userId}/reports/{reportId}.
     * @allow (create) User with UID 'userId' can create a report.
     * @deny (create) User with UID 'otherUserId' cannot create report at /users/{userId}/reports/{reportId}.
     * @allow (update) User with UID 'userId' can update their own report.
     * @deny (update) User with UID 'otherUserId' cannot update report at /users/{userId}/reports/{reportId}.
     * @allow (delete) User with UID 'userId' can delete their own report.
     * @deny (delete) User with UID 'otherUserId' cannot delete report at /users/{userId}/reports/{reportId}.
     * @principle Enforces path-based ownership for all operations on reports.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

     /**
      * @description Secures the partners collection.  Currently allows public read and write.
      * @path /partners/{partnerId}
      * @allow (get) Any user can read partner data.
      * @allow (list) Any user can list partner data.
      * @allow (create) Any authenticated user can create a partner.
      * @allow (update) Any authenticated user can update a partner.
      * @allow (delete) Any authenticated user can delete a partner.
      * @principle Placeholder for partner security.  Consider restricting access in a production environment.
      */
    match /partners/{partnerId} {
        allow get, list: if true; //Open to read
        allow create, update, delete: if true;  //Any autheticated user can create, update, or delete partners

    }
  }
}