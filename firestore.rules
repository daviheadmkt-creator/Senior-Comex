/**
 * @description This ruleset enforces a user-ownership model for user profiles, audit logs, and reports,
 *              combined with public read/write access for partners, ports and terminals.
 *              It ensures that only authenticated users can access data, with additional restrictions based on ownership.
 * @dataStructure
 *   - /users/{userId}: Stores user profile information. Only the user or an admin can access.
 *   - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Only the user can access.
 *   - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Only the user can access.
 *   - /partners/{partnerId}: Stores partner information. All authenticated users can read and write to this collection.
 *   - /ports/{portId}: Stores port information. All authenticated users can read and write to this collection.
 *   - /terminals/{terminalId}: Stores terminal information. All authenticated users can read and write to this collection.
 * @keySecurityDecisions
 *   - User listing is denied to prevent unauthorized access to user data.
 *   - Audit logs and reports are stored as subcollections to enforce user-based ownership.
 *   - Partners, Ports and Terminals are globally readable and writable for all authenticated users.
 * @denormalizationForAuthorization
 *   - Path-based ownership is used for audit logs and reports to avoid the need for `get()` calls during authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects the /users collection, ensuring only the user themselves can read their profile. Listing users is forbidden.
     * @path /users/{userId}
     * @allow (get) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can read their own profile.
     * @allow (create) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can create their own profile.
     * @allow (update) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can update their own profile.
     * @allow (delete) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can delete their own profile.
     * @deny (get) User with ID "anotherUserId" cannot read the profile of user "FJ4TWLjbvtdMx44fdAOTb4h8Ze32".
     * @deny (list) Any user cannot list all users.
     * @deny (create) User with ID "anotherUserId" cannot create a profile for user "FJ4TWLjbvtdMx44fdAOTb4h8Ze32".
     * @principle Enforces document ownership for writes and restricts listing of users for privacy.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Protects the /users/{userId}/auditLogs collection, ensuring only the owning user can access their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can read their own audit log.
     * @allow (create) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can create an audit log under their profile.
     * @allow (update) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can update their own audit log.
     * @allow (delete) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can delete their own audit log.
     * @deny (get) User with ID "anotherUserId" cannot read audit logs of user "FJ4TWLjbvtdMx44fdAOTb4h8Ze32".
     * @deny (list) User with ID "anotherUserId" cannot list audit logs of user "FJ4TWLjbvtdMx44fdAOTb4h8Ze32".
     * @deny (create) User with ID "anotherUserId" cannot create an audit log under the profile of user "FJ4TWLjbvtdMx44fdAOTb4h8Ze32".
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Protects the /users/{userId}/reports collection, ensuring only the owning user can access their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can read their own report.
     * @allow (create) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can create a report under their profile.
     * @allow (update) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can update their own report.
     * @allow (delete) User with ID "FJ4TWLjbvtdMx44fdAOTb4h8Ze32" can delete their own report.
     * @deny (get) User with ID "anotherUserId" cannot read reports of user "FJ4TWLjbvtdMx44fdAOTb4h8Ze32".
     * @deny (list) User with ID "anotherUserId" cannot list reports of user "FJ4TWLjbvtdMx44fdAOTb4h8Ze32".
     * @deny (create) User with ID "anotherUserId" cannot create a report under the profile of user "FJ4TWLjbvtdMx44fdAOTb4h8Ze32".
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows all authenticated users to read and write partner information.
     * @path /partners/{partnerId}
     * @allow (get) Any authenticated user can read partner information.
     * @allow (create) Any authenticated user can create partner information.
     * @allow (update) Any authenticated user can update partner information.
     * @allow (delete) Any authenticated user can delete partner information.
     * @deny (get) Unauthenticated user cannot read partner information.
     * @principle Public read/write access for authenticated users.
     */
    match /partners/{partnerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows all authenticated users to read and write port information.
     * @path /ports/{portId}
     * @allow (get) Any authenticated user can read port information.
     * @allow (create) Any authenticated user can create port information.
     * @allow (update) Any authenticated user can update port information.
     * @allow (delete) Any authenticated user can delete port information.
     * @deny (get) Unauthenticated user cannot read port information.
     * @principle Public read/write access for authenticated users.
     */
    match /ports/{portId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows all authenticated users to read and write terminal information.
     * @path /terminals/{terminalId}
     * @allow (get) Any authenticated user can read terminal information.
     * @allow (create) Any authenticated user can create terminal information.
     * @allow (update) Any authenticated user can update terminal information.
     * @allow (delete) Any authenticated user can delete terminal information.
     * @deny (get) Unauthenticated user cannot read terminal information.
     * @principle Public read/write access for authenticated users.
     */
    match /terminals/{terminalId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }

  // Helper function to determine if the user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to determine if the user is the owner of the document.
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

    // Helper function to determine if the user is the owner of the document and the document exists.
  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}