/**
 * @file Firestore Security Rules for SeniorComex application.
 * @core_philosophy This ruleset enforces a strict user-ownership model for user-related data (profiles, audit logs, reports).
 *   Partners data is accessible to all authenticated users.
 * @data_structure
 *   - `/users/{userId}`: Stores user profile information.
 *   - `/users/{userId}/auditLogs/{auditLogId}`: Stores audit logs for each user.
 *   - `/users/{userId}/reports/{reportId}`: Stores reports generated by each user.
 *   - `/partners/{partnerId}`: Stores partner information.
 * @key_security_decisions
 *   - Only the owner can read/write their user document.
 *   - Audit logs and reports are subcollections under the user and thus are only accessible by that user.
 *   - Listing of all users is explicitly denied to prevent information disclosure.
 *   - All authenticated users can read and write to the `/partners` collection.
 * @denormalization_for_authorization Path-based ownership is used to relate AuditLog and Report documents to users, avoiding `get()` calls for authorization.
 * @structural_segregation User-specific data (audit logs, reports) are stored in subcollections to ensure clear ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to user profile data.
     * @path /users/{userId}
     * @allow (get) User with matching ID can read their own profile.
     * @allow (create) User with matching ID can create their own profile.
     * @allow (update) User with matching ID can update their own profile.
     * @deny (list) Prevents listing all users.
     * @deny (create) User cannot create profile for another user.
     * @deny (update) User cannot update another user's profile.
     * @principle Enforces document ownership for reads and writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages access to audit logs for a specific user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get) User with matching ID can read their own audit logs.
     * @allow (create) User with matching ID can create audit logs under their own profile.
     * @allow (update) User with matching ID can update audit logs under their own profile.
     * @allow (list) User with matching ID can list their own audit logs.
     * @deny (create) User cannot create audit logs for another user.
     * @deny (update) User cannot update another user's audit logs.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
       function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages access to reports generated by a specific user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get) User with matching ID can read their own reports.
     * @allow (create) User with matching ID can create reports under their own profile.
     * @allow (update) User with matching ID can update reports under their own profile.
     * @allow (list) User with matching ID can list their own reports.
     * @deny (create) User cannot create reports for another user.
     * @deny (update) User cannot update another user's reports.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

       /**
     * @description Manages access to partner information.
     * @path /partners/{partnerId}
     * @allow (get) Any authenticated user can read partner data.
     * @allow (list) Any authenticated user can list partner data.
     * @allow (create) Any authenticated user can create partner data.
     * @allow (update) Any authenticated user can update partner data.
     * @allow (delete) Any authenticated user can delete partner data.
     * @principle Allows all authenticated users to read and write partner data.
     */
    match /partners/{partnerId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
    }
  }
}