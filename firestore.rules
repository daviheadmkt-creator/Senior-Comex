/**
 * @file Firestore Security Rules for SeniorComex Application
 * @core_philosophy This ruleset enforces a strict user-ownership model for user-related data (profiles, audit logs, and reports) and a public read with owner-only writes model for partner data. It prioritizes security by default, explicitly denying access unless specifically granted.
 * @data_structure
 * - `/users/{userId}`: Stores user profiles, with each document ID matching the user's authentication UID.
 * - `/users/{userId}/auditLogs/{auditLogId}`: Stores audit logs specific to a user.
 * - `/users/{userId}/reports/{reportId}`: Stores reports generated by a user.
 * - `/partners/{partnerId}`: Stores partner information with public read access and owner-only write access (requires an `ownerId` field).
 * @key_security_decisions
 * - Users can only access their own data (profiles, audit logs, and reports).
 * - Listing of users is forbidden to prevent information disclosure.
 * - Audit logs and reports are only accessible to the user who owns them.
 * - Partner data is publicly readable but only writable by the owner (if an `ownerId` field exists in the `Partner` schema).
 * @denormalization_for_authorization
 * - User ownership is enforced through path-based matching (e.g., `/users/{userId}`), eliminating the need for `get()` calls to verify ownership.
 * @structural_segregation
 * - User-specific data (audit logs, reports) is stored in subcollections under the user's document, ensuring clear ownership and simplifying access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces ownership for user profiles. Only the authenticated user can read or write their own profile.
     * @path /users/{userId}
     * @allow (create) - User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create their profile if request.auth.uid == userId.
     * @allow (get, update, delete) - User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can get, update, or delete their profile if request.auth.uid == userId.
     * @deny (create) - User 'anotherUser' cannot create a profile with userId 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (get, update, delete) - User 'anotherUser' cannot get, update, or delete the profile of user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      // Check if the user is signed in.
      allow get: if isOwner(userId);
      allow list: if false;

      // Only allow creating a user document if the authenticated user's ID matches the document ID.
      allow create: if isSignedIn() && isSelfCreation(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      function isSelfCreation(userId) {
        return request.auth.uid == userId;
      }
    }

    /**
     * @description Enforces ownership for audit logs. Only the owner user can read or write their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) - User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create an audit log under their profile.
     * @allow (get, list, update, delete) - User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can get, list, update, or delete their own audit logs.
     * @deny (create) - User 'anotherUser' cannot create an audit log for user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (get, list, update, delete) - User 'anotherUser' cannot get, list, update, or delete audit logs for user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Enforces ownership for reports. Only the owner user can read or write their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) - User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create a report under their profile.
     * @allow (get, list, update, delete) - User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can get, list, update, or delete their own reports.
     * @deny (create) - User 'anotherUser' cannot create a report for user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @deny (get, list, update, delete) - User 'anotherUser' cannot get, list, update, or delete reports for user 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows public read access to partner data and restricts write access to the owner.
     * @path /partners/{partnerId}
     * @allow (get, list) - Any user can read partner data.
     * @allow (create) - Only the authenticated user can create a partner document AND the `ownerId` field in the document must match the authenticated user's UID.
     * @allow (update, delete) - Only the owner of the partner document can update or delete it.
     * @deny (create) - Creation will be denied if the `ownerId` in the document does not match the authenticated user's UID.
     * @deny (update, delete) - Update and delete operations will be denied if the user is not the owner of the document.
     * @principle Enforces public read access with owner-only writes.
     */
    match /partners/{partnerId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isSignedIn() && request.auth.uid == resource.data.ownerId && resource != null;
    }
  }
}