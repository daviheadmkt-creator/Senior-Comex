/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-related data (profiles, audit logs, reports).
 * Partner data is publicly readable but only writable by authorized users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs related to a specific user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by a specific user.
 * - /partners/{partnerId}: Stores partner information.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data, audit logs, and reports.
 * - Listing of audit logs and reports is allowed only for the owner.
 * - Partner information is publicly readable. Writes to partner information are not currently secured and require a TODO.
 *
 * Denormalization for Authorization:
 *  - AuditLog and Report documents are stored as subcollections under each user document (`/users/{userId}/auditLogs/{auditLogId}` and `/users/{userId}/reports/{reportId}`), ensuring clear ownership and simplifying access control.
 *
 * Structural Segregation:
 *  - User-specific data (auditLogs, reports) are stored in subcollections, guaranteeing private access, while partner data is stored in a top-level collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) - Authenticated user can create their own user document if the userId matches their auth UID.
     * @allow (get, update, delete) - Authenticated user can get, update, and delete their own user document.
     * @deny (create) - User cannot create a document with a userId that does not match their auth UID.
     * @deny (get, update, delete) - User cannot get, update, or delete another user's document.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource.data != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // User listing is not permitted.

      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to audit logs for a specific user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) - Authenticated user can create an audit log under their user document.
     * @allow (get, list) - Authenticated user can get and list audit logs under their user document.
     * @allow (update, delete) - Authenticated user can update and delete audit logs under their user document.
     * @deny (create) - User cannot create an audit log under another user's document.
     * @deny (get, list, update, delete) - User cannot get, list, update, or delete audit logs under another user's document.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

        function isExistingOwner(userId) {
          return isOwner(userId) && resource.data != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to reports generated by a specific user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) - Authenticated user can create a report under their user document.
     * @allow (get, list) - Authenticated user can get and list reports under their user document.
     * @allow (update, delete) - Authenticated user can update and delete reports under their user document.
     * @deny (create) - User cannot create a report under another user's document.
     * @deny (get, list, update, delete) - User cannot get, list, update, or delete reports under another user's document.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

        function isExistingOwner(userId) {
          return isOwner(userId) && resource.data != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

       /**
     * @description Controls access to partner information.
     * @path /partners/{partnerId}
     * @allow (get, list) - All users can read partner information.
     * @allow (create, update, delete) - Not currently secured, requires additional authorization logic.
     * @principle Public read access with restricted writes.
     */
    match /partners/{partnerId} {
        allow get, list: if true;
        allow create, update, delete: if false; // TODO: Add owner validation once roles are implemented.
    }
  }
}