rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (get) User with ID 'user123' can read their own profile.
     * @allow (create) User with ID 'user123' can create their own profile.
     * @allow (update) User with ID 'user123' can update their own profile.
     * @deny (get) User with ID 'user456' cannot read the profile of user 'user123'.
     * @deny (create) User with ID 'user456' cannot create the profile of user 'user123'.
     * @deny (update) User with ID 'user456' cannot update the profile of user 'user123'.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to audit logs for a specific user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get) User with ID 'user123' can read their own audit log.
     * @allow (create) User with ID 'user123' can create an audit log for themselves.
     * @allow (update) User with ID 'user123' can update their own audit log.
     * @deny (get) User with ID 'user456' cannot read the audit log of user 'user123'.
     * @deny (create) User with ID 'user456' cannot create an audit log for user 'user123'.
     * @deny (update) User with ID 'user456' cannot update the audit log of user 'user123'.
     * @principle Enforces document ownership for audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to reports generated by a specific user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get) User with ID 'user123' can read their own report.
     * @allow (create) User with ID 'user123' can create a report for themselves.
     * @allow (update) User with ID 'user123' can update their own report.
     * @deny (get) User with ID 'user456' cannot read the report of user 'user123'.
     * @deny (create) User with ID 'user456' cannot create a report for user 'user123'.
     * @deny (update) User with ID 'user456' cannot update the report of user 'user123'.
     * @principle Enforces document ownership for reports.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to partner information.
     * @path /partners/{partnerId}
     * @allow (get) Any authenticated user can read partner information.
     * @allow (create) Any authenticated user can create partner information.
     * @allow (update) Any authenticated user can update partner information.
     * @principle Allows any authenticated user to read and write partner data.
     */
    match /partners/{partnerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Controls access to port information.
     * @path /ports/{portId}
     * @allow (get) Any authenticated user can read port information.
     * @allow (create) Any authenticated user can create port information.
     * @allow (update) Any authenticated user can update port information.
     * @principle Allows any authenticated user to read and write port data.
     */
    match /ports/{portId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Controls access to terminal information.
     * @path /terminals/{terminalId}
     * @allow (get) Any authenticated user can read terminal information.
     * @allow (create) Any authenticated user can create terminal information.
     * @allow (update) Any authenticated user can update terminal information.
     * @principle Allows any authenticated user to read and write terminal data.
     */
    match /terminals/{terminalId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Controls access to export/import processes.
     * @path /processos/{processoId}
     * @allow (get) Any authenticated user can read process information.
     * @allow (create) Any authenticated user can create process information.
     * @allow (update) Any authenticated user can update process information.
     * @principle Allows any authenticated user to read and write process data.
     */
    match /processos/{processoId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
  }
}