/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports,
 *              and provides separate read/write access control for partner data.
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profiles, accessible only to the user themselves.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs related to a specific user, accessible only to that user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by a specific user, accessible only to that user.
 * - /partners/{partnerId}: Stores partner data, accessible to authenticated users.
 *
 * Key Security Decisions:
 * - User profiles are private and only accessible to the owning user. Listing of all users is denied.
 * - Audit logs and reports are user-specific subcollections, ensuring that only the owning user can access them.
 * - Partner data is accessible to all authenticated users.
 *
 * Denormalization for Authorization:
 * - The data model employs path-based ownership for `auditLogs` and `reports`, nesting them under the respective `/users/{userId}` document.
 *   This avoids the need for costly `get()` calls to authorize access to these subcollections.
 *   The rules can simply check the `request.auth.uid` against the `userId` path parameter.
 *
 * Structural Segregation:
 * - The use of user-specific subcollections (`/users/{userId}/auditLogs`, `/users/{userId}/reports`) ensures that private user data is kept separate
 *   from potentially public data (if the application were to have any). This segregation improves both security and query performance.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the user profile data. Only the authenticated user can read or write their own profile.
     * @path /databases/{database}/documents/users/{userId}
     * @allow (create) User with ID "in34VaH79wdKPVFlnFsbwtbRbUr2" can create their profile.
     * @allow (get, update, delete) Authenticated user "in34VaH79wdKPVFlnFsbwtbRbUr2" can get, update, or delete their own profile.
     * @deny (create) User with ID "otherUserId" cannot create a profile with userId "in34VaH79wdKPVFlnFsbwtbRbUr2".
     * @deny (get, update, delete) Authenticated user "otherUserId" cannot get, update, or delete the profile of user "in34VaH79wdKPVFlnFsbwtbRbUr2".
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Do not allow listing of all users.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures audit logs for each user. Only the authenticated user can read or write their own audit logs.
     * @path /databases/{database}/documents/users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User with ID "in34VaH79wdKPVFlnFsbwtbRbUr2" can create an audit log under their profile.
     * @allow (get, update, delete) Authenticated user "in34VaH79wdKPVFlnFsbwtbRbUr2" can get, update, or delete their own audit logs.
     * @deny (create) User with ID "otherUserId" cannot create an audit log under the profile of user "in34VaH79wdKPVFlnFsbwtbRbUr2".
     * @deny (get, update, delete) Authenticated user "otherUserId" cannot get, update, or delete audit logs under the profile of user "in34VaH79wdKPVFlnFsbwtbRbUr2".
     * @principle Enforces document ownership for all operations, leveraging path-based ownership.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures reports for each user. Only the authenticated user can read or write their own reports.
     * @path /databases/{database}/documents/users/{userId}/reports/{reportId}
     * @allow (create) User with ID "in34VaH79wdKPVFlnFsbwtbRbUr2" can create a report under their profile.
     * @allow (get, update, delete) Authenticated user "in34VaH79wdKPVFlnFsbwtbRbUr2" can get, update, or delete their own reports.
     * @deny (create) User with ID "otherUserId" cannot create a report under the profile of user "in34VaH79wdKPVFlnFsbwtbRbUr2".
     * @deny (get, update, delete) Authenticated user "otherUserId" cannot get, update, or delete reports under the profile of user "in34VaH79wdKPVFlnFsbwtbRbUr2".
     * @principle Enforces document ownership for all operations, leveraging path-based ownership.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
    
    /**
     * @description Secures the partner data. All authenticated users can read partner data. Only authenticated users can create, update, or delete partner data.
     * @path /databases/{database}/documents/partners/{partnerId}
     * @allow (get, list) Any authenticated user can read partner data.
     * @allow (create, update, delete) Any authenticated user can create, update, or delete partner data.
     * @principle Authenticated users can create, update, and delete partner data.
     */
    match /partners/{partnerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if resource != null && isSignedIn();
      allow delete: if resource != null && isSignedIn();
    }
  }

  // Helper function to determine if the user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to determine if the user is the owner of the document.
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  // Helper function to determine if the user is the owner of an EXISTING document.
  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}