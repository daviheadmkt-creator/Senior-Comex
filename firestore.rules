/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports.
 * All data is nested under /users/{userId}, ensuring that each user can only access their own data.
 * Partner data is stored at the top level, and is not user specific.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Only the authenticated user can read/write their own profile.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Only the user can read/write their own audit logs.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Only the user can read/write their own reports.
 * - /partners/{partnerId}: Stores partner information.
 *
 * Key Security Decisions:
 * - User listing is explicitly denied to prevent information disclosure.
 * - All write operations are restricted to the authenticated user, based on the user ID in the path.
 * - No schema validation is enforced in this prototyping phase, except for ownership checks.
 * - The partner collection has open read and write access. This should be revisited for production.
 *
 * Denormalization for Authorization:
 * - Path-based ownership is used for auditLogs and reports, eliminating the need for `get()` calls to verify ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Defines a global function to check if the user is signed in.
     * @principle Requires all requests to originate from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Defines a global function to check if the authenticated user is the owner of the resource based on the user ID in the path.
     * @param {string} userId - The user ID from the path.
     * @principle Enforces user-ownership for all operations.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Defines a global function to check if the authenticated user is the owner of the resource based on the user ID in the path and if the resource exists.
     * @param {string} userId - The user ID from the path.
     * @principle Enforces user-ownership and resource existence for destructive operations.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Secures the /users/{userId} collection to allow only the authenticated user to manage their own profile.
     * @path /users/{userId}
     * @allow (create) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create their own profile at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @allow (get) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can read their own profile at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @allow (update) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can update their own profile at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @allow (delete) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can delete their own profile at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @deny (create) User 'attackerId' cannot create a profile for 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @deny (get) User 'attackerId' cannot read the profile of 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @deny (update) User 'attackerId' cannot update the profile of 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @deny (delete) User 'attackerId' cannot delete the profile of 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Listing users is not allowed.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures the /users/{userId}/auditLogs/{auditLogId} collection to allow only the authenticated user to manage their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create an audit log at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @allow (get) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can read their audit log at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @allow (update) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can update their audit log at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @allow (delete) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can delete their audit log at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @deny (create) User 'attackerId' cannot create an audit log for 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @deny (get) User 'attackerId' cannot read the audit log of 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @deny (update) User 'attackerId' cannot update the audit log of 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @deny (delete) User 'attackerId' cannot delete the audit log of 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures the /users/{userId}/reports/{reportId} collection to allow only the authenticated user to manage their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create a report at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @allow (get) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can read their report at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @allow (update) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can update their report at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @allow (delete) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can delete their report at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @deny (create) User 'attackerId' cannot create a report for 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @deny (get) User 'attackerId' cannot read the report of 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @deny (update) User 'attackerId' cannot update the report of 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @deny (delete) User 'attackerId' cannot delete the report of 'in34VaH79wdKPVFlnFsbwtbRbUr2' at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.generatedByUserId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.generatedByUserId == resource.data.generatedByUserId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures the /partners/{partnerId} collection.  In this prototyping phase, all authenticated users can read and write partner data.
     * @path /partners/{partnerId}
     * @allow (create) Any authenticated user can create a partner.
     * @allow (get) Any authenticated user can read a partner.
     * @allow (update) Any authenticated user can update a partner.
     * @allow (delete) Any authenticated user can delete a partner.
     * @principle Open read and write access for prototyping.
     */
    match /partners/{partnerId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }
}