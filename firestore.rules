/**
 * @file Firestore Security Rules for SeniorComex application.
 * @description This ruleset enforces a hybrid security model:
 *   - User profiles and associated data (audit logs, reports) follow a strict user-ownership model.
 *   - Shared collections (partners, ports, terminals, processos) allow authenticated users to read and write.
 *   - The rules prioritize security and maintainability by using helper functions to abstract complex logic.
 *   - Data validation is limited to fields critical for authorization and relational integrity, supporting rapid prototyping.
 *
 * @dataStructure
 *   - /users/{userId}: Stores user profile information.
 *   - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user.
 *   - /users/{userId}/reports/{reportId}: Stores reports generated by each user.
 *   - /partners/{partnerId}: Stores partner information.
 *   - /ports/{portId}: Stores port information.
 *   - /terminals/{terminalId}: Stores terminal information.
 *   - /processos/{processoId}: Stores export/import process information.
 *
 * @keySecurityDecisions
 *   - Users can only read/write their own profile data (ownership model).
 *   - Audit logs and reports are secured under user-specific subcollections, enforcing path-based ownership.
 *   - Listing of all users is explicitly denied to prevent information disclosure.
 *   - Shared collections are writeable by any authenticated user to facilitate collaboration.
 *
 * @denormalizationForAuthorization
 *   - The current data model does not require denormalization. The `User`, `AuditLog`, and `Report` entities are correctly linked by path-based ownership which can easily enforced through rules.
 *
 * @structuralSegregation
 *   - The structure effectively segregates private user data (profiles, audit logs, reports) from shared data (partners, ports, terminals, processos) using different collections and access control policies.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Ensures the user is signed in
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the request is made by the owner of the user document.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Combines ownership check with existence check for update/delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /***************** User Profile Rules *****************/

    /**
     * @description Allows a user to read their own profile and create their own profile document. Denies listing all users.
     * @path /users/{userId}
     * @allow (get) User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' can read their own profile.
     * @allow (create) User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' can create their own profile.
     * @deny (get) User 'anotherUser' cannot read User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' profile.
     * @deny (create) User 'anotherUser' cannot create User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' profile.
     * @principle Enforces document ownership for reads and writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Explicitly deny listing all users

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /***************** Audit Log Rules *****************/

    /**
     * @description Allows a user to read and write audit logs for their own profile.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get) User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' can read their own audit logs.
     * @allow (create) User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' can create their own audit logs.
     * @deny (get) User 'anotherUser' cannot read User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' audit logs.
     * @deny (create) User 'anotherUser' cannot create User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' audit logs.
     * @principle Enforces path-based document ownership for reads and writes.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /***************** Report Rules *****************/

    /**
     * @description Allows a user to read and write reports for their own profile.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get) User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' can read their own reports.
     * @allow (create) User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' can create their own reports.
     * @deny (get) User 'anotherUser' cannot read User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' reports.
     * @deny (create) User 'anotherUser' cannot create User 'FJ4TWLjbvtdMx44fdAOTb4h8Ze32' reports.
     * @principle Enforces path-based document ownership for reads and writes.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /***************** Partner Rules *****************/

    /**
     * @description Allows any authenticated user to read and write partner information.
     * @path /partners/{partnerId}
     * @allow (get) Any signed-in user can read partner information.
     * @allow (create) Any signed-in user can create partner information.
     * @principle Allows public read and write access to the partners collection for any authenticated user.
     */
    match /partners/{partnerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
    
    /***************** Port Rules *****************/

    /**
     * @description Allows any authenticated user to read and write port information.
     * @path /ports/{portId}
     * @allow (get) Any signed-in user can read port information.
     * @allow (create) Any signed-in user can create port information.
     * @principle Allows public read and write access to the ports collection for any authenticated user.
     */
    match /ports/{portId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();

        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    /***************** Terminal Rules *****************/

    /**
     * @description Allows any authenticated user to read and write terminal information.
     * @path /terminals/{terminalId}
     * @allow (get) Any signed-in user can read terminal information.
     * @allow (create) Any signed-in user can create terminal information.
     * @principle Allows public read and write access to the terminals collection for any authenticated user.
     */
    match /terminals/{terminalId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();

        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    /***************** Processo Rules *****************/

    /**
     * @description Allows any authenticated user to read and write export/import process information.
     * @path /processos/{processoId}
     * @allow (get) Any signed-in user can read process information.
     * @allow (create) Any signed-in user can create process information.
     * @principle Allows public read and write access to the processos collection for any authenticated user.
     */
    match /processos/{processoId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }
}