/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user-generated data (audit logs, reports)
 *              and allows public read access to partners while restricting writes.
 *
 * Data Structure:
 * - /users/{userId}/auditLogs/{auditLogId}: Audit logs owned by a specific user.
 * - /users/{userId}/reports/{reportId}: Reports owned by a specific user.
 * - /partners/{partnerId}: Publicly readable partner data, write-restricted.
 *
 * Key Security Decisions:
 * - User listing is explicitly denied at the root /users collection for security reasons.
 * - Read access to partner data is public, but creation, update, and deletion are denied, since the schema does not include an owner field.
 *
 * Denormalization for Authorization:
 * - AuditLog and Report documents are stored as subcollections of the user document. This avoids the need for get() calls during authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing document.
     */
    function isExistingOwner(userId) {
      return isSignedIn() && request.auth.uid == userId && resource.data != null;
    }

    /**
     * @description Denies listing of all users.
     * @path /users
     * @allow None - Listing users is not permitted.
     * @deny Any - Listing users is always denied.
     * @principle Prevents information disclosure by disallowing user enumeration.
     */
    match /users {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages access to audit logs for individual users.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create an audit log under their own user ID.
     * @deny (create) User 'someOtherUserId' cannot create an audit log under user ID 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @principle Enforces document ownership for writes, restricting data modification to the owning user.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) ;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages access to reports for individual users.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create a report under their own user ID.
     * @deny (create) User 'someOtherUserId' cannot create an audit log under user ID 'in34VaH79wdKPVFlnFsbwtbRbUr2'.
     * @principle Enforces document ownership for writes, restricting data modification to the owning user.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages access to partner information. Public read, restricted writes.
     * @path /partners/{partnerId}
     * @allow (get, list) Any user can read partner information.
     * @deny (create, update, delete) No user can create, update, or delete partner information.
     * @principle Allows public read access while restricting write access due to missing ownership field.
     */
    match /partners/{partnerId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }
}