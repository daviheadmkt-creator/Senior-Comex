/**
 * @file Firestore Security Rules for SeniorComex Application
 *
 * @core_philosophy This ruleset enforces a strict user-ownership model for user-related data (audit logs, reports).
 *   Partners are open to read and write by all authenticated users.
 * @data_structure
 *   - /users/{userId}: Stores user profile information.
 *   - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user.
 *   - /users/{userId}/reports/{reportId}: Stores reports generated by each user.
 *   - /partners/{partnerId}: Stores partner information.
 * @key_security_decisions
 *   - Listing all users is denied to prevent information disclosure.
 *   - Audit logs and reports are only accessible by the owning user.
 *   - Partners can be read and written to by all authenticated users.
 * @denormalization_for_authorization N/A (Path-based ownership is used)
 * @structural_segregation N/A
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for user profile information.
     * @path /users/{userId}
     * @allow (create) Authenticated user can create their own profile if the userId matches their auth.uid.
     * @allow (get, update, delete) Authenticated user can only access their own profile.
     * @deny (list) Listing all users is not allowed.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == request.auth.uid;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces access control for audit logs. Only the owning user can access their audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) Authenticated user can create audit logs under their profile.
     * @allow (get, list, update, delete) Authenticated user can only access audit logs under their profile.
     * @deny  User cannot create audit logs for other users.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces access control for reports. Only the owning user can access their reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) Authenticated user can create reports under their profile.
     * @allow (get, list, update, delete) Authenticated user can only access reports under their profile.
     * @deny  User cannot create reports for other users.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

       /**
     * @description Allows any authenticated user to read and write partner data.
     * @path /partners/{partnerId}
     * @allow (get, list) Any authenticated user can read partner data.
     * @allow (create, update, delete) Any authenticated user can modify partner data.
     * @principle Open read/write access for authenticated users.
     */
    match /partners/{partnerId} {
        function isSignedIn() {
            return request.auth != null;
        }
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
    }
  }
}