/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-related data (audit logs, reports),
 * ensuring that only the authenticated user can access their own data. The Partner collection has no ownership defined.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs related to a specific user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by a specific user.
 * - /partners/{partnerId}: Stores partner information. There are no access controls enforced, so anyone can read/write.
 *
 * Key Security Decisions:
 * - Users can only list their own subcollections (auditLogs and reports).
 * - Listing the `/users` collection is denied to prevent unauthorized access to user information.
 * - Partner collection is left open for prototyping (TODO: Implement access controls).
 *
 * Denormalization for Authorization:
 * - The rules leverage path-based ownership to determine authorization, avoiding the need for `get()` calls
 *   to retrieve parent document data. This is achieved by nesting auditLogs and reports under their respective user documents.
 *   This approach ensures Authorization Independence and atomic operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Prevents listing all users. Users can only be created through Firebase Authentication.
     * @path /users
     * @allow (get) Authenticated user can fetch any user.
     * @deny (list) No user can list all users.
     * @deny (create) No user can create new users directly through firestore.
     * @deny (update) No user can update user list directly through firestore.
     * @deny (delete) No user can delete users directly through firestore.
     * @principle Prevents unauthorized access to user information.
     */
    match /users {
        allow get: if isSignedIn();
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Manages access to individual user documents.
     * @path /users/{userId}
     * @allow (create) Authenticated user can create their own user document (self-registration).
     * @allow (get) Authenticated user can fetch their own user document.
     * @allow (update) Authenticated user can update their own user document.
     * @allow (delete) Authenticated user can delete their own user document.
     * @deny (create) An unauthenticated user tries to create a user document.
     * @deny (get) An unauthenticated user tries to fetch a user document.
     * @deny (update) An unauthenticated user tries to update a user document.
     * @deny (delete) An unauthenticated user tries to delete a user document.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Manages access to audit log entries for a specific user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) Authenticated user can create audit logs under their own user document.
     * @allow (get) Authenticated user can fetch audit logs under their own user document.
     * @allow (list) Authenticated user can list audit logs under their own user document.
     * @allow (update) Authenticated user can update audit logs under their own user document.
     * @allow (delete) Authenticated user can delete audit logs under their own user document.
     * @deny (create) An unauthenticated user tries to create an audit log entry.
     * @deny (get) An unauthenticated user tries to fetch an audit log entry.
     * @deny (list) An unauthenticated user tries to list audit log entries.
     * @deny (update) An unauthenticated user tries to update an audit log entry.
     * @deny (delete) An unauthenticated user tries to delete an audit log entry.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Manages access to reports generated by a specific user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) Authenticated user can create reports under their own user document.
     * @allow (get) Authenticated user can fetch reports under their own user document.
     * @allow (list) Authenticated user can list reports under their own user document.
     * @allow (update) Authenticated user can update reports under their own user document.
     * @allow (delete) Authenticated user can delete reports under their own user document.
     * @deny (create) An unauthenticated user tries to create a report.
     * @deny (get) An unauthenticated user tries to fetch a report.
     * @deny (list) An unauthenticated user tries to list reports.
     * @deny (update) An unauthenticated user tries to update a report.
     * @deny (delete) An unauthenticated user tries to delete a report.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Manages access to partner information.
     * @path /partners/{partnerId}
     * @allow (create) Any authenticated user can create partner information.
     * @allow (get) Any authenticated user can fetch partner information.
     * @allow (list) Any authenticated user can list partner information.
     * @allow (update) Any authenticated user can update partner information.
     * @allow (delete) Any authenticated user can delete partner information.
     * @principle TODO: Implement access controls based on user roles and partner relationships.
     */
    match /partners/{partnerId} {
          // TODO: Add more restrictive rules once access control requirements are established.
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update: if isSignedIn() && resource != null;
          allow delete: if isSignedIn() && resource != null;
    }
  }
}

/**
 * @description Checks if the user is signed in.
 * @return {boolean} True if the user is signed in, false otherwise.
 */
function isSignedIn() {
  return request.auth != null;
}

/**
 * @description Checks if the user is the owner of the document.
 * @param {string} userId The user ID to compare against the request's authentication UID.
 * @return {boolean} True if the user is the owner, false otherwise.
 */
function isOwner(userId) {
  return request.auth.uid == userId;
}

/**
 * @description Checks if the user is the owner of the existing document.
 * @param {string} userId The user ID to compare against the request's authentication UID.
 * @return {boolean} True if the user is the owner and the resource exists, false otherwise.
 */
function isExistingOwner(userId) {
  return isOwner(userId) && resource != null;
}