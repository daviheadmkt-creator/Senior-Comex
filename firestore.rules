/**
 * @file Firebase Security Rules for SeniorComex Application
 *
 * @core_philosophy This ruleset enforces a strict user-ownership model for user-related data (audit logs, reports),
 * ensuring that users can only access their own data.  Partner data is publicly readable, but only
 * authenticated users can modify it.
 *
 * @data_structure
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs specific to a user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by a user.
 * - /partners/{partnerId}: Stores partner information.
 *
 * @key_security_decisions
 * - User listing is disallowed to protect user privacy.
 * - Audit logs and reports are strictly owned by the user ID in their path.
 * - Partners are publicly readable but only writable by authenticated users.
 *
 * @denormalization_for_authorization
 * - AuditLog and Report documents are stored as subcollections of `/users/{userId}`. This denormalization means
 *   that we don't need to perform extra `get()` operations to verify ownership. The rules can simply check
 *   the path to determine if the user is the owner.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Prevents listing all users to protect privacy.  Allows access to a specific user document only by that user.
     * @path /users/{userId}
     * @allow (get) User with ID 'user123' reads their own profile.
     * @deny (get) User with ID 'user456' attempts to read profile of 'user123'.
     * @allow (create) User 'user123' creates their own profile.
     * @deny (create) User 'user123' attempts to create profile for 'user456'.
     * @allow (update) User 'user123' updates their own profile.
     * @deny (update) User 'user123' attempts to update profile of 'user456'.
     * @allow (delete) User 'user123' deletes their own profile.
     * @deny (delete) User 'user123' attempts to delete profile of 'user456'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows a user to manage their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User 'user123' creates a new audit log entry under their user ID.
     * @deny (create) User 'user123' attempts to create an audit log entry under 'user456'.
     * @allow (get) User 'user123' retrieves audit log entry 'log1' from their own audit logs.
     * @deny (get) User 'user123' attempts to retrieve audit log entry 'log1' from 'user456' audit logs.
     * @allow (update) User 'user123' updates audit log entry 'log1' in their own audit logs.
     * @deny (update) User 'user123' attempts to update audit log entry 'log1' in 'user456' audit logs.
     * @allow (delete) User 'user123' deletes audit log entry 'log1' in their own audit logs.
     * @deny (delete) User 'user123' attempts to delete audit log entry 'log1' in 'user456' audit logs.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows a user to manage their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User 'user123' creates a report under their user ID.
     * @deny (create) User 'user123' attempts to create a report under 'user456'.
     * @allow (get) User 'user123' retrieves 'report1' from their own reports.
     * @deny (get) User 'user123' attempts to retrieve 'report1' from 'user456' reports.
     * @allow (update) User 'user123' updates 'report1' in their own reports.
     * @deny (update) User 'user123' attempts to update 'report1' in 'user456' reports.
     * @allow (delete) User 'user123' deletes 'report1' in their own reports.
     * @deny (delete) User 'user123' attempts to delete 'report1' in 'user456' reports.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.generatedByUserId == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

     /**
      * @description Allows public read access to partner information, but restricts write access to authenticated users.
      * @path /partners/{partnerId}
      * @allow (get) Any user (authenticated or not) can read partner data.
      * @allow (list) Any user (authenticated or not) can list partner data.
      * @deny (create) An unauthenticated user attempts to create partner data.
      * @allow (create) An authenticated user creates partner data.
      * @deny (update) An unauthenticated user attempts to update partner data.
      * @allow (update) An authenticated user updates partner data.
      * @deny (delete) An unauthenticated user attempts to delete partner data.
      * @allow (delete) An authenticated user deletes partner data.
      * @principle Provides public read access with authenticated write access.
      */
    match /partners/{partnerId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    // Example from the initial file.
     match /processos/{docId} {
      allow read: if isSignedIn() && request.auth.token.email_verified == true;
      allow list: if isSignedIn() && request.auth.token.email_verified == true;
      allow create: if isSignedIn() && request.auth.token.email_verified == true;
      allow update: if isSignedIn() && request.auth.token.email_verified == true && resource != null;
      allow delete: if isSignedIn() && request.auth.token.email_verified == true && resource != null;
    }

  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}