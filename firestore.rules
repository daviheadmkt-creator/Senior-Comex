
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Helper function to check if a user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Controls access to user profile data.
     */
    match /users/{userId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      function isAdmin() {
          return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Administrador';
      }

      // Allow a user to create/read/update/delete their own profile.
      allow read, write: if isSignedIn() && isOwner();
      
      // Allow an admin to list all users.
      allow list: if isSignedIn() && isAdmin();
    }
    
    /**
     * @description Grants access to the 'partners' collection for any authenticated user.
     */
    match /partners/{partnerId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Grants access to the 'ports' collection for any authenticated user.
     */
    match /ports/{portId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Grants access to the 'terminals' collection for any authenticated user.
     */
    match /terminals/{terminalId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Grants access to the 'processos' collection for any authenticated user.
     */
    match /processos/{processoId} {
      allow read, write: if isSignedIn();
    }
  }
}
