rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔹 Regra para a coleção 'processos'
    match /processos/{docId} {
      allow read, write: if request.auth != null;
    }

    // 🔹 Regra para a coleção 'partners'
    match /partners/{partnerId} {
      allow read, write: if request.auth != null;
    }

    // 🔹 Regra para a coleção 'users'
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner() {
        return request.auth.uid == userId;
      }
      function isAdmin() {
        // Acesso ao documento do próprio usuário para verificar a função
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Administrador';
      }

      // Usuário pode ler o próprio perfil
      allow get: if isSignedIn() && isOwner();
      
      // Admin pode listar todos os usuários
      allow list: if isSignedIn() && isAdmin();

      // Usuário pode criar e atualizar o próprio perfil
      allow write: if isSignedIn() && isOwner();
    }

    // 🔹 Regras para subcoleções de 'users'
    match /users/{userId}/{collection}/{docId} {
       // Usuário só pode acessar suas próprias subcoleções
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
