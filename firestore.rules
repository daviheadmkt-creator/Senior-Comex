rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an admin
    function isUserAdmin(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.funcao == 'Administrador';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // READ:
      // - Admins can read (get) any user document.
      // - Any authenticated user can read their own document.
      // - Admins can list all users.
      allow get: if request.auth != null && (isUserAdmin(request.auth.uid) || request.auth.uid == userId);
      allow list: if request.auth != null && isUserAdmin(request.auth.uid);

      // WRITE:
      // - Admins can create new users.
      allow create: if request.auth != null && isUserAdmin(request.auth.uid);
      // - Admins can update any user.
      // - Authenticated users can update their own document.
      allow update: if request.auth != null && (isUserAdmin(request.auth.uid) || request.auth.uid == userId);
      // - Admins can delete any user.
      allow delete: if request.auth != null && isUserAdmin(request.auth.uid);
    }

    // Rules for subcollections of 'users'
    match /users/{userId}/{subcollection}/{docId} {
      // Allow full access if the user is the owner of the parent user document.
      // This covers AuditLog and Report collections.
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for the 'partners' collection
    match /partners/{partnerId} {
      // Allow any authenticated user to read and write to the partners collection.
      allow read, write: if request.auth != null;
    }
  }
}
