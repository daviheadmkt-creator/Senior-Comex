/**
 * @fileOverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports.
 * It provides open access to partner data for all authenticated users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only to the user themselves.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user, accessible only to the user themselves.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user, accessible only to the user themselves.
 * - /partners/{partnerId}: Stores partner information, accessible to all authenticated users.
 *
 * Key Security Decisions:
 * - User listing is denied to prevent unauthorized access to user data.
 * - All write operations are strictly controlled based on ownership.
 * - Audit Logs and Reports are namespaced under users to provide Authorization Independence.
 *
 * Denormalization for Authorization:
 * - The `userId` is encoded directly in the path for auditLogs and reports.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects the /users collection. Only the user themselves can read their profile.
     * @path /users/{userId}
     * @allow (get) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can read their own profile (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @allow (create) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can create their own profile (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @allow (update) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can update their own profile (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @allow (delete) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can delete their own profile (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @deny (get) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to read User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 profile.
     * @deny (create) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to create User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 profile.
     * @deny (update) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to update User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 profile.
     * @deny (delete) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to delete User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 profile.
     * @deny (list) Any user tries to list all the users in the /users collection.
     * @principle Enforces document ownership for all operations on user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Protects the /users/{userId}/auditLogs collection. Only the user themselves can read/write their audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can read their own auditLog (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @allow (create) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can create their own auditLog (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @allow (update) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can update their own auditLog (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @allow (delete) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can delete their own auditLog (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @deny (get) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to read User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 auditLog.
     * @deny (create) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to create User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 auditLog.
     * @deny (update) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to update User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 auditLog.
     * @deny (delete) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to delete User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 auditLog.
     * @principle Enforces document ownership for all operations on audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Protects the /users/{userId}/reports collection. Only the user themselves can read/write their reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can read their own report (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @allow (create) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can create their own report (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @allow (update) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can update their own report (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @allow (delete) User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 can delete their own report (userId: FJ4TWLjbvtdMx44fdAOTb4h8Ze32).
     * @deny (get) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to read User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 report.
     * @deny (create) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to create User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 report.
     * @deny (update) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to update User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 report.
     * @deny (delete) User W5a6y2z8ui1X9p0LnM4bQ7rJs3H7 tries to delete User FJ4TWLjbvtdMx44fdAOTb4h8Ze32 report.
     * @principle Enforces document ownership for all operations on reports.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows all authenticated users to read and write partner data.
     * @path /partners/{partnerId}
     * @allow (get) Any authenticated user can read any partner.
     * @allow (create) Any authenticated user can create any partner.
     * @allow (update) Any authenticated user can update any partner.
     * @allow (delete) Any authenticated user can delete any partner.
     * @principle Allows open access to partner data for all authenticated users.
     */
    match /partners/{partnerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }

  // Helper Functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isSignedIn() && isOwner(userId) && resource != null;
  }
}