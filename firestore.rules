rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Only the authenticated user can read or write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Only admins can list users
      allow list: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Administrador';
    }

    match /partners/{partnerId} {
        // Any authenticated user can read, write, create, update, delete partners
        allow read, write: if request.auth != null;
    }
    
    match /processos/{docId} {
      allow list, get, create, update, delete: if request.auth != null;
    }

  }
}
