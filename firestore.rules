/**
 * @file Firestore Security Rules for SeniorComex Application
 * @description This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles. Only the authenticated user can read/write their own profile.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Only the owning user can read/write their own audit logs.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Only the owning user can read/write their own reports.
 * - /partners/{partnerId}: Stores partner information. Create, Update, and Delete operations are restricted to authenticated users. Reads are public.
 *
 * Key Security Decisions:
 * - Users can only access their own data (profiles, audit logs, and reports).
 * - Data validation is relaxed to allow for rapid prototyping, but ownership and relational integrity are strictly enforced.
 * - Public read access is granted for the /partners collection, but write access is restricted.
 *
 * Denormalization for Authorization:
 * - The userId is encoded in the document path for /users/{userId}, /users/{userId}/auditLogs/{auditLogId}, and /users/{userId}/reports/{reportId},
 *   eliminating the need to store the userId within the document itself and simplifying authorization checks.
 *   The rules will check if `request.auth.uid == userId` to grant access.
 *
 * Structural Segregation:
 * - AuditLogs and Reports are stored as subcollections under the respective user's document. This ensures Authorization Independence and simplifies security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profiles.
     * @path /users/{userId}
     * @allow (create) - Authenticated user can create their own profile. The `id` field must match their `auth.uid`.
     * @allow (get, update, delete) - Authenticated user can get, update, and delete their own profile.
     * @deny (create, update, delete) - Any other user attempts to create, update, or delete another user's profile.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to audit logs for a specific user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) - Authenticated user can create an audit log under their own profile.
     * @allow (get, update, delete) - Authenticated user can get, update, and delete their own audit logs.
     * @deny (create, update, delete) - Any other user attempts to create, update, or delete audit logs under another user's profile.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
        function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to reports generated by a specific user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) - Authenticated user can create a report under their own profile.
     * @allow (get, update, delete) - Authenticated user can get, update, and delete their own reports.
     * @deny (create, update, delete) - Any other user attempts to create, update, or delete reports under another user's profile.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to partner information.
     * @path /partners/{partnerId}
     * @allow (get, list) - Anyone can read partner information.
     * @allow (create, update, delete) - Only authenticated users can create, update, or delete partner information.
     * @principle Public read access with owner-only writes.
     */
     match /partners/{partnerId} {
        function isSignedIn() {
            return request.auth != null;
        }
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }
  }
}