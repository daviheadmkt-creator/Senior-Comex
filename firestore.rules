/**
 * @fileOverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports.
 * It provides open access to partners.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Only the authenticated user can access their own profile.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Only the authenticated user can access their own audit logs.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Only the authenticated user can access their own reports.
 * - /partners/{partnerId}: Stores partner information.  This collection has open access for all authenticated users.
 *
 * Key Security Decisions:
 * - Users can only access their own data (profile, audit logs, reports).
 * - Audit logs and reports are stored as subcollections under each user, enforcing clear ownership.
 * - Listing the entire 'users' collection is disallowed.
 * - Partner information is accessible to all authenticated users.
 *
 * Denormalization for Authorization:
 * - The data structure uses path-based ownership. This avoids the need for `get()` calls to retrieve parent document data during authorization, ensuring atomic operations and easier debugging.
 *   For example, the rules for `/users/{userId}/auditLogs/{auditLogId}` directly check if `request.auth.uid == userId`.
 *
 * Structural Segregation:
 * - User-specific data (profile, audit logs, reports) is stored under the `/users/{userId}` path, while public data (partner) is stored in a top-level collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for user profile information. Only the authenticated user can read and write their own profile.
     * @path /users/{userId}
     * @allow (create) - An authenticated user can create their own profile if the userId matches their auth UID.
     * @allow (get, update, delete) - An authenticated user can read, update, and delete their profile if the userId matches their auth UID.
     * @deny (create) - An authenticated user cannot create a profile with a userId that does not match their auth UID.
     * @deny (get, update, delete) - An authenticated user cannot read, update, or delete another user's profile.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces access control for audit logs. Only the authenticated user can read and write their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) - An authenticated user can create an audit log under their own user ID.
     * @allow (get, update, delete) - An authenticated user can read, update, and delete audit logs under their own user ID.
     * @deny (create) - An authenticated user cannot create an audit log under another user's ID.
     * @deny (get, update, delete) - An authenticated user cannot read, update, or delete audit logs under another user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
       function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }
            function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces access control for reports. Only the authenticated user can read and write their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) - An authenticated user can create a report under their own user ID.
     * @allow (get, update, delete) - An authenticated user can read, update, and delete reports under their own user ID.
     * @deny (create) - An authenticated user cannot create a report under another user's ID.
     * @deny (get, update, delete) - An authenticated user cannot read, update, or delete reports under another user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/reports/{reportId} {
       function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.generatedByUserId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.generatedByUserId == resource.data.generatedByUserId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows all authenticated users to read and write partner information.
     * @path /partners/{partnerId}
     * @allow (get, list) - Any authenticated user can read partner information.
     * @allow (create, update, delete) - Any authenticated user can create, update, and delete partner information.
     * @principle Open access for authenticated users.
     */
    match /partners/{partnerId} {
       function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }
}