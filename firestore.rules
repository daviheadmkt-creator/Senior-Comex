/**
 * @fileoverview Firestore Security Rules for SeniorComex application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-related data (audit logs, reports),
 * with a separate collection for partners that has open read access for all users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs specific to each user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user.
 * - /partners/{partnerId}: Stores partner information.
 *
 * Key Security Decisions:
 * - User listing is implicitly denied via the lack of `allow list` rule on the `/users` collection.
 * - Audit logs and reports are strictly owned by the user ID in the path.
 * - Partner information is visible to all users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for user profiles.
     * @path /users/{userId}
     * @allow (create) If the user is creating their own profile (auth.uid == userId).
     * @allow (get) If the user is requesting their own profile (auth.uid == userId).
     * @allow (update) If the user is updating their own profile (auth.uid == userId).
     * @allow (delete) If the user is deleting their own profile (auth.uid == userId).
     * @deny (list) Listing all users is not permitted.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Rules for audit logs, stored under a user's profile.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) If the user is creating an audit log for their own profile (auth.uid == userId).
     * @allow (get) If the user is requesting an audit log for their own profile (auth.uid == userId).
     * @allow (update) If the user is updating an audit log for their own profile (auth.uid == userId).
     * @allow (delete) If the user is deleting an audit log for their own profile (auth.uid == userId).
     * @principle Enforces document ownership for audit logs within a user's data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Rules for reports, stored under a user's profile.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) If the user is creating a report for their own profile (auth.uid == userId).
     * @allow (get) If the user is requesting a report for their own profile (auth.uid == userId).
     * @allow (update) If the user is updating a report for their own profile (auth.uid == userId).
     * @allow (delete) If the user is deleting a report for their own profile (auth.uid == userId).
     * @principle Enforces document ownership for reports within a user's data tree.
     */
    match /users/{userId}/reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Rules for partner information.  Partners are readable by everyone, but only writeable by a server.
     * @path /partners/{partnerId}
     * @allow (get) Allow anyone to read partner information.
     * @allow (list) Allow anyone to read partner information.
     * @deny (create) Do not allow client-side creation.
     * @deny (update) Do not allow client-side updates.
     * @deny (delete) Do not allow client-side deletes.
     * @principle Allows public read access but restricts write access.
     */
    match /partners/{partnerId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}