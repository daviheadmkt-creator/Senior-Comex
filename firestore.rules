/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a hybrid security model.
 *
 * Core Philosophy:
 * - User-owned data is strictly controlled via path-based ownership (/users/{userId} and subcollections).
 * - Public data (partners, ports, terminals, processos) allows authenticated access.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles; only the owner and admins can read.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs; only the owner can read/write.
 * - /users/{userId}/reports/{reportId}: Stores reports; only the owner can read/write.
 * - /partners/{partnerId}: Stores partner data; all authenticated users can read/write.
 * - /ports/{portId}: Stores port data; all authenticated users can read/write.
 * - /terminals/{terminalId}: Stores terminal data; all authenticated users can read/write.
 * - /processos/{processoId}: Stores process data; all authenticated users can read/write.
 *
 * Key Security Decisions:
 * - Users cannot list all user profiles (except admins - not yet implemented).
 * - Data validation is relaxed to allow rapid prototyping. Only authorization-critical fields are validated.
 *
 * Denormalization for Authorization:
 * - User documents store the 'funcao' (role) to avoid needing separate role lookups.
 *
 * Structural Segregation:
 * - Private user data (auditLogs, reports) is stored in user subcollections, while public data (partners, ports, terminals, processos) is stored in top-level collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by a signed-in user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided userId.
     * @param {string} userId - The user ID to compare against.
     * @return {bool} - True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided userId and the resource exists.
     * @param {string} userId - The user ID to compare against.
     * @return {bool} - True if the user is the owner and the document exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /users/{userId} collection.
     * @path /users/{userId}
     * @allow (get) User with ID 'user123' can read their own profile.
     *    - auth.uid: 'user123'
     *    - operation: get
     * @allow (create) User with ID 'user456' can create their own profile.
     *    - auth.uid: 'user456'
     *    - operation: create
     * @deny (get) User with ID 'user123' cannot read another user's profile.
     *    - auth.uid: 'user789'
     *    - operation: get
     * @principle Enforces document ownership for reads and writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Listing all users is not permitted.

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/auditLogs/{auditLogId} collection.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get) User with ID 'user123' can read their own audit logs.
     *    - auth.uid: 'user123'
     *    - operation: get
     * @allow (create) User with ID 'user456' can create audit logs under their own profile.
     *    - auth.uid: 'user456'
     *    - operation: create
     * @deny (get) User with ID 'user123' cannot read another user's audit logs.
     *    - auth.uid: 'user789'
     *    - operation: get
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/reports/{reportId} collection.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get) User with ID 'user123' can read their own reports.
     *    - auth.uid: 'user123'
     *    - operation: get
     * @allow (create) User with ID 'user456' can create reports under their own profile.
     *    - auth.uid: 'user456'
     *    - operation: create
     * @deny (get) User with ID 'user123' cannot read another user's reports.
     *    - auth.uid: 'user789'
     *    - operation: get
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /partners/{partnerId} collection.
     * @path /partners/{partnerId}
     * @allow (get) Any authenticated user can read partner data.
     *    - auth.uid: 'anyuser'
     *    - operation: get
     * @allow (create) Any authenticated user can create partner data.
     *    - auth.uid: 'anyuser'
     *    - operation: create
     * @principle Allows authenticated access to partner data.
     */
    match /partners/{partnerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Rules for the /ports/{portId} collection.
     * @path /ports/{portId}
     * @allow (get) Any authenticated user can read port data.
     *    - auth.uid: 'anyuser'
     *    - operation: get
     * @allow (create) Any authenticated user can create port data.
     *    - auth.uid: 'anyuser'
     *    - operation: create
     * @principle Allows authenticated access to port data.
     */
    match /ports/{portId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Rules for the /terminals/{terminalId} collection.
     * @path /terminals/{terminalId}
     * @allow (get) Any authenticated user can read terminal data.
     *    - auth.uid: 'anyuser'
     *    - operation: get
     * @allow (create) Any authenticated user can create terminal data.
     *    - auth.uid: 'anyuser'
     *    - operation: create
     * @principle Allows authenticated access to terminal data.
     */
    match /terminals/{terminalId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Rules for the /processos/{processoId} collection.
     * @path /processos/{processoId}
     * @allow (get) Any authenticated user can read process data.
     *    - auth.uid: 'anyuser'
     *    - operation: get
     * @allow (create) Any authenticated user can create process data.
     *    - auth.uid: 'anyuser'
     *    - operation: create
     * @principle Allows authenticated access to process data.
     */
    match /processos/{processoId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }
}