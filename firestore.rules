rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile data.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their own profile.
     * @allow (get) User with ID 'user123' can read their profile.
     * @allow (update) User with ID 'user123' can update their profile.
     * @allow (delete) User with ID 'user123' can delete their profile.
     * @deny (create) User with ID 'user123' cannot create a profile for 'user456'.
     * @deny (update) User with ID 'user123' cannot update the profile of 'user456'.
     * @principle Enforces document ownership for writes and reads based on the userId.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to audit logs for a specific user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User with ID 'user123' can create an audit log in their own collection.
     * @allow (get) User with ID 'user123' can read an audit log from their own collection.
     * @allow (update) User with ID 'user123' can update an audit log in their own collection.
     * @allow (delete) User with ID 'user123' can delete an audit log from their own collection.
     * @deny (create) User with ID 'user123' cannot create an audit log in 'user456's collection.
     * @deny (update) User with ID 'user123' cannot update an audit log in 'user456's collection.
     * @principle Restricts access to a user's own audit logs based on the userId.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to reports generated by a specific user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User with ID 'user123' can create a report in their own collection.
     * @allow (get) User with ID 'user123' can read a report from their own collection.
     * @allow (update) User with ID 'user123' can update a report in their own collection.
     * @allow (delete) User with ID 'user123' can delete a report from their own collection.
     * @deny (create) User with ID 'user123' cannot create a report in 'user456's collection.
     * @deny (update) User with ID 'user123' cannot update a report in 'user456's collection.
     * @principle Restricts access to a user's own reports based on the userId.
     */
    match /users/{userId}/reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

       /**
     * @description Controls access to partner information.  Partners are publicly readable, but only modifiable by the owner.
     * @path /partners/{partnerId}
     * @allow (get) Any user can read partner information.
     * @allow (list) Any user can list partner information.
     * @allow (create) Only authenticated users can create partner information. The 'ownerId' field must match the authenticated user's ID.
     * @allow (update) Only the owner of the partner document can update it.
     * @allow (delete) Only the owner of the partner document can delete it.
     * @deny (create) An unauthenticated user cannot create partner information.
     * @deny (update) A user cannot update a partner document they don't own.
     * @principle Allows public read access with owner-only writes for partners.
     */
    match /partners/{partnerId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.generatedByUserId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.generatedByUserId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.generatedByUserId == request.auth.uid;
    }
    
        /**
     * @description Public access to the list of ports.
     * @path /ports
     * @allow (get) Any user can read port information.
     * @allow (list) Any user can list port information.
     * @deny (create) An unauthenticated user cannot create port information.
     * @deny (update) A user cannot update a port document.
     *
     */
     match /ports/{portId} {
        allow get: if true;
        allow list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }
  }
}