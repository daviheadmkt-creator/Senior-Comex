/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for the SeniorComex application.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles. Only the user can read/write their own profile.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Only the user can read/write their own logs.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Only the user can read/write their own reports.
 *
 * Key Security Decisions:
 * - Users can only access their own data.
 * - Listing of users is disallowed to prevent information disclosure.
 * - The rules do not validate the data schema but enforce user ownership.
 *
 * Denormalization for Authorization:
 * - Path-based ownership is enforced, requiring the `userId` in the path to match the authenticated user's UID.
 *   This avoids the need for `get()` calls to retrieve user data for authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for user profiles.
     * @path /users/{userId}
     * @allow (create) - Authenticated user creates their own profile with matching userId.
     * @allow (get, update, delete) - Authenticated user accesses their own profile.
     * @deny (create) - Authenticated user attempts to create a profile with a mismatched userId.
     * @deny (get, update, delete) - Authenticated user attempts to access another user's profile.
     * @principle Enforces strict user-ownership for all operations on user profiles.
     */
    match /users/{userId} {
      // Helper function to check if the authenticated user is the owner of the document.
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Helper function to check if the authenticated user is the existing owner of the document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // Disallowing listing of all users

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id; //Enforce immutability of userId
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) - Authenticated user creates an audit log under their own user ID.
     * @allow (get, update, delete) - Authenticated user accesses their own audit logs.
     * @deny (create) - Authenticated user attempts to create an audit log under a different user ID.
     * @deny (get, update, delete) - Authenticated user attempts to access another user's audit logs.
     * @principle Enforces strict user-ownership for all operations on audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
       // Helper function to check if the authenticated user is the owner of the document.
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Helper function to check if the authenticated user is the existing owner of the document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) - Authenticated user creates a report under their own user ID.
     * @allow (get, update, delete) - Authenticated user accesses their own reports.
     * @deny (create) - Authenticated user attempts to create a report under a different user ID.
     * @deny (get, update, delete) - Authenticated user attempts to access another user's reports.
     * @principle Enforces strict user-ownership for all operations on reports.
     */
    match /users/{userId}/reports/{reportId} {
       // Helper function to check if the authenticated user is the owner of the document.
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Helper function to check if the authenticated user is the existing owner of the document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}