/**
 * @file Firestore Security Rules for SeniorComex Application
 *
 * @core_philosophy This ruleset enforces a strict user-ownership model for data stored under `/users/{userId}`.
 *  Users can only access their own data. Audit logs and reports are stored as subcollections under each user,
 *  with denormalized `userId` fields to simplify authorization.
 *
 * @data_structure
 *  - `/users/{userId}`: Stores user profile data.
 *  - `/users/{userId}/auditLogs/{auditLogId}`: Stores audit logs related to a specific user. Each audit log document
 *    includes a `userId` field that MUST match the `userId` in the path.
 *  - `/users/{userId}/reports/{reportId}`: Stores reports generated by a specific user. Each report document
 *    includes a `userId` field that MUST match the `userId` in the path.
 *
 * @key_security_decisions
 *  - Users can only create their own user document, and only if the `userId` in the path matches their `auth.uid`.
 *  - Listing all users is disallowed.
 *  - Audit Logs and Reports are accessible only to the user to whom they belong.
 *
 * @denormalization_for_authorization The `AuditLog` and `Report` documents contain a `userId` field that duplicates
 *  the `userId` found in the document path. This denormalization is crucial for security because it allows the rules
 *  to quickly verify ownership without performing additional `get()` operations.
 *
 * @structural_segregation User-specific data (AuditLogs, Reports) are stored under their respective `/users/{userId}` paths,
 *  separating it from other user data. This allows for specific security rules to be applied to a user's data without
 *  affecting other users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile data.
     * @path /users/{userId}
     * @allow (create) User with matching UID can create their own profile.
     * @deny (create) User attempts to create a profile with a different userId.
     * @deny (update) User attempts to update another user's profile.
     * @principle Enforces document ownership and prevents unauthorized modifications.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Allow a user to create their own profile if the userId matches their auth.uid.
      allow create: if isSignedIn()
                    && isOwner(userId)
                    && request.resource.data.id == request.auth.uid;

      // Allow a user to read their own profile.
      allow get: if isSignedIn() && isOwner(userId);

      // Prevent listing all users.
      allow list: if false;

      // Allow a user to update their own profile, but enforce immutability of the id field.
      allow update: if isSignedIn() && isOwner(userId) && resource != null && request.resource.data.id == resource.data.id;

      // Allow a user to delete their own profile.
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

    /**
     * @description Controls access to audit logs for a specific user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) User can create an audit log under their own user ID.
     * @deny (create) User attempts to create an audit log under another user's ID.
     * @deny (update) User attempts to modify another user's audit log.
     * @principle Enforces document ownership and prevents unauthorized modifications of audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Allow a user to create an audit log if the userId matches their auth.uid.
      allow create: if isSignedIn()
                    && isOwner(userId)
                    && request.resource.data.userId == userId;

      // Allow a user to read their own audit logs.
      allow get: if isSignedIn() && isOwner(userId);

      // Allow a user to list their own audit logs.
      allow list: if isSignedIn() && isOwner(userId);

      // Allow a user to update their own audit log, but enforce that the userId cannot be changed.
      allow update: if isSignedIn()
                    && isOwner(userId)
                    && resource != null
                    && request.resource.data.userId == resource.data.userId;

      // Allow a user to delete their own audit log.
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

    /**
     * @description Controls access to reports for a specific user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User can create a report under their own user ID.
     * @deny (create) User attempts to create a report under another user's ID.
     * @deny (update) User attempts to modify another user's report.
     * @principle Enforces document ownership and prevents unauthorized modifications of reports.
     */
    match /users/{userId}/reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Allow a user to create a report if the userId matches their auth.uid.
      allow create: if isSignedIn()
                    && isOwner(userId)
                    && request.resource.data.userId == userId;

      // Allow a user to read their own reports.
      allow get: if isSignedIn() && isOwner(userId);

      // Allow a user to list their own reports.
      allow list: if isSignedIn() && isOwner(userId);

      // Allow a user to update their own report, but enforce that the userId cannot be changed.
      allow update: if isSignedIn()
                    && isOwner(userId)
                    && resource != null
                    && request.resource.data.userId == resource.data.userId;

      // Allow a user to delete their own report.
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}