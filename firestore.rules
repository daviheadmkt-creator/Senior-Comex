/**
 * @file Overview
 * This ruleset enforces a strict user-ownership model for `users`, `auditLogs`, and `reports` subcollections.
 * All data is nested under `/users/{userId}`, ensuring that only the authenticated user can access their own data.
 * The `partners` collection allows public reads, but restricts writes to authenticated users only.
 * User listing is denied for security reasons.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles. Each user can only access their own profile.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Each user can only access their own audit logs.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Each user can only access their own reports.
 * - /partners/{partnerId}: Stores partner information.
 *
 * Key Security Decisions:
 * - User listing is explicitly denied.
 * - Path-based ownership is enforced for `users`, `auditLogs`, and `reports`. The `userId` path segment must match the authenticated user's UID.
 * - Public read access to the `partners` collection, but owner-only writes.
 *
 * Authorization Independence:
 * - AuditLog and Report documents are related to users using path based ownership (`/users/{userId}/auditLogs/{auditLogId}` and `/users/{userId}/reports/{reportId}`). This avoids the need for `get()` calls to retrieve parent document data during authorization, ensuring atomic operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces strict user-ownership for user profiles. Only the authenticated user can read or write their own profile.
     * @path /users/{userId}
     * @allow (create) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create their own profile at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @allow (get) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can read their profile at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @allow (update) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can update their profile at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @allow (delete) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can delete their profile at /users/in34VaH79wdKPVFlnFsbwtbRbUr2.
     * @deny (create) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot create a profile at /users/someOtherUserId.
     * @deny (get) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot read another user's profile at /users/someOtherUserId.
     * @deny (update) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot update another user's profile at /users/someOtherUserId.
     * @deny (delete) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot delete another user's profile at /users/someOtherUserId.
     * @principle Enforces document ownership for all operations. Validates the path-based userId against the authenticated user's UID.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Listing users is not permitted.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for audit logs. Only the authenticated user can read or write their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (create) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create an audit log at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @allow (get) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can read their audit log at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @allow (list) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can list their audit logs at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs.
     * @allow (update) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can update their audit log at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @allow (delete) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can delete their audit log at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/auditLogs/someAuditLogId.
     * @deny (create) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot create an audit log for another user at /users/someOtherUserId/auditLogs/someAuditLogId.
     * @deny (get) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot read another user's audit log at /users/someOtherUserId/auditLogs/someAuditLogId.
     * @deny (list) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot list another user's audit logs at /users/someOtherUserId/auditLogs.
     * @deny (update) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot update another user's audit log at /users/someOtherUserId/auditLogs/someAuditLogId.
     * @deny (delete) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot delete another user's audit log at /users/someOtherUserId/auditLogs/someAuditLogId.
     * @principle Enforces document ownership for all operations. Validates the path-based userId against the authenticated user's UID.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for reports. Only the authenticated user can read or write their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can create a report at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @allow (get) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can read their report at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @allow (list) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can list their reports at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports.
     * @allow (update) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can update their report at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @allow (delete) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' can delete their report at /users/in34VaH79wdKPVFlnFsbwtbRbUr2/reports/someReportId.
     * @deny (create) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot create a report for another user at /users/someOtherUserId/reports/someReportId.
     * @deny (get) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot read another user's report at /users/someOtherUserId/reports/someReportId.
     * @deny (list) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot list another user's reports at /users/someOtherUserId/reports.
     * @deny (update) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot update another user's report at /users/someOtherUserId/reports/someReportId.
     * @deny (delete) - Authenticated user with UID 'in34VaH79wdKPVFlnFsbwtbRbUr2' cannot delete another user's report at /users/someOtherUserId/reports/someReportId.
     * @principle Enforces document ownership for all operations. Validates the path-based userId against the authenticated user's UID.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.generatedByUserId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.generatedByUserId == resource.data.generatedByUserId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to partner information, but restricts write access to authenticated users.
     * @path /partners/{partnerId}
     * @allow (get) - Any user (authenticated or not) can read partner information.
     * @allow (list) - Any user (authenticated or not) can list partners.
     * @allow (create) - Authenticated user can create a partner.
     * @allow (update) - Authenticated user can update a partner.
     * @allow (delete) - Authenticated user can delete a partner.
     * @deny (create) - Non-authenticated user cannot create a partner.
     * @deny (update) - Non-authenticated user cannot update a partner.
     * @deny (delete) - Non-authenticated user cannot delete a partner.
     * @principle Allows public read access, but enforces authentication for write operations.
     */
    match /partners/{partnerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}