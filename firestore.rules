rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user has a specific role
    function isUserRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == role;
    }
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
        return request.auth != null;
    }

    // Users Collection
    match /users/{userId} {
      // Admins can read/write any user profile.
      // Users can read/update their own profile.
      allow read: if isUserRole('Administrador') || request.auth.uid == userId;
      allow write: if isUserRole('Administrador');
      allow update: if request.auth.uid == userId;
      // Creation of user documents is handled by a secure backend process/Cloud Function
      // after initial authentication, so direct client creation is denied.
      allow create: if isAuthenticated();
      // Only admins can delete users.
      allow delete: if isUserRole('Administrador');
    }
    
    match /users/{userId} {
        // Only Admins should be able to list all users
        allow list: if isUserRole('Administrador');
    }

    // Partners, Ports, and Terminals Collections
    match /{collection}/{docId} where collection in ['partners', 'ports', 'terminals'] {
      // All authenticated users can read and write to these reference data collections.
      allow read, write: if isAuthenticated();
    }
    
    // Processos Collection
    match /processos/{processoId} {
        // All authenticated users can manage processes.
        allow read, write: if isAuthenticated();
    }
    
    // Subcollections
    match /users/{userId}/{subcollection}/{docId} {
      // Access is granted if the user is the owner of the parent user document.
      allow read, write: if request.auth.uid == userId;
    }
  }
}
    