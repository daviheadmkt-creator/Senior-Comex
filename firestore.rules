/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user-specific data (profiles, audit logs, reports) while allowing open access to partner, port, terminal, and process data.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Only the user or an admin can access this data.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user. Only the user can access their own audit logs.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user. Only the user can access their own reports.
 * - /partners/{partnerId}: Stores partner information. All authenticated users can read and write.
 * - /ports/{portId}: Stores port information. All authenticated users can read and write.
 * - /terminals/{terminalId}: Stores terminal information. All authenticated users can read and write.
 * - /processos/{processoId}: Stores process information. All authenticated users can read, create, update, and delete.
 *
 * Key Security Decisions:
 * - User data is strictly controlled, with access limited to the owning user.
 * - Read-only collections are not used; all collections are designed for both read and write operations based on authentication.
 * - The default security posture for ambiguous relationships is strict owner-only access.
 * - Listing the entire `/users` collection is explicitly denied to prevent unauthorized access to user data.
 *
 * Denormalization for Authorization:
 * - User-specific data (auditLogs, reports) is stored as subcollections under the `/users/{userId}` path. This enforces path-based ownership, eliminating the need for `get()` calls to verify ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by an authenticated user.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @return {bool} True if the user is signed in and the UID matches, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId, and that the resource exists.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @return {bool} True if the user is signed in, the UID matches, and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
   

    /**
     * @description Secures the /users/{userId} collection, allowing users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (get) User with UID 'user123' can retrieve their own profile: request.auth.uid == 'user123'
     * @allow (create) User with UID 'user123' can create their own profile: request.auth.uid == 'user123'
     * @allow (update) User with UID 'user123' can update their own profile: request.auth.uid == 'user123'
     * @allow (delete) User with UID 'user123' can delete their own profile: request.auth.uid == 'user123'
     * @deny (get) User with UID 'user456' cannot retrieve the profile of user 'user123': request.auth.uid != 'user123'
     * @deny (create) User with UID 'user456' cannot create the profile of user 'user123': request.auth.uid != 'user123'
     * @deny (update) User with UID 'user456' cannot update the profile of user 'user123': request.auth.uid != 'user123'
     * @deny (delete) User with UID 'user456' cannot delete the profile of user 'user123': request.auth.uid != 'user123'
     * @principle Enforces document ownership for reads and writes to user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      // Listing users is not permitted.
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures the /users/{userId}/auditLogs/{auditLogId} collection, allowing users to manage their own audit logs.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (get) User with UID 'user123' can retrieve their own audit log 'log456': request.auth.uid == 'user123'
     * @allow (create) User with UID 'user123' can create an audit log 'log456' under their profile: request.auth.uid == 'user123'
     * @allow (update) User with UID 'user123' can update their audit log 'log456': request.auth.uid == 'user123'
     * @allow (delete) User with UID 'user123' can delete their own audit log 'log456': request.auth.uid == 'user123'
     * @deny (get) User with UID 'user456' cannot retrieve audit log 'log456' of user 'user123': request.auth.uid != 'user123'
     * @deny (create) User with UID 'user456' cannot create audit log 'log456' under the profile of user 'user123': request.auth.uid != 'user123'
     * @deny (update) User with UID 'user456' cannot update audit log 'log456' of user 'user123': request.auth.uid != 'user123'
     * @deny (delete) User with UID 'user456' cannot delete audit log 'log456' of user 'user123': request.auth.uid != 'user123'
     * @principle Restricts access to a user's own audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures the /users/{userId}/reports/{reportId} collection, allowing users to manage their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get) User with UID 'user123' can retrieve their own report 'report456': request.auth.uid == 'user123'
     * @allow (create) User with UID 'user123' can create a report 'report456' under their profile: request.auth.uid == 'user123'
     * @allow (update) User with UID 'user123' can update their own report 'report456': request.auth.uid == 'user123'
     * @allow (delete) User with UID 'user123' can delete their own report 'report456': request.auth.uid == 'user123'
     * @deny (get) User with UID 'user456' cannot retrieve report 'report456' of user 'user123': request.auth.uid != 'user123'
     * @deny (create) User with UID 'user456' cannot create report 'report456' under the profile of user 'user123': request.auth.uid != 'user123'
     * @deny (update) User with UID 'user456' cannot update report 'report456' of user 'user123': request.auth.uid != 'user123'
     * @deny (delete) User with UID 'user456' cannot delete report 'report456' of user 'user123': request.auth.uid != 'user123'
     * @principle Restricts access to a user's own reports.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.generatedByUserId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.generatedByUserId == resource.data.generatedByUserId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows any authenticated user to read and write partner data.
     * @path /partners/{partnerId}
     * @allow (get) Any authenticated user can retrieve partner data.
     * @allow (list) Any authenticated user can list partner data.
     * @allow (create) Any authenticated user can create partner data.
     * @allow (update) Any authenticated user can update partner data.
     * @allow (delete) Any authenticated user can delete partner data.
     * @principle Allows open read and write access to partner data for authenticated users.
     */
    match /partners/{partnerId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write port data.
     * @path /ports/{portId}
     * @allow (get) Any authenticated user can retrieve port data.
     * @allow (list) Any authenticated user can list port data.
     * @allow (create) Any authenticated user can create port data.
     * @allow (update) Any authenticated user can update port data.
     * @allow (delete) Any authenticated user can delete port data.
     * @principle Allows open read and write access to port data for authenticated users.
     */
    match /ports/{portId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write terminal data.
     * @path /terminals/{terminalId}
     * @allow (get) Any authenticated user can retrieve terminal data.
     * @allow (list) Any authenticated user can list terminal data.
     * @allow (create) Any authenticated user can create terminal data.
     * @allow (update) Any authenticated user can update terminal data.
     * @allow (delete) Any authenticated user can delete terminal data.
     * @principle Allows open read and write access to terminal data for authenticated users.
     */
    match /terminals/{terminalId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read, write and delete processes data.
     * @path /processos/{processoId}
     * @allow (get) Any authenticated user can retrieve process data.
     * @allow (list) Any authenticated user can list process data.
     * @allow (create) Any authenticated user can create process data.
     * @allow (update) Any authenticated user can update process data.
     * @allow (delete) Any authenticated user can delete process data.
     * @principle Allows open read and write access to process data for authenticated users.
     */
    match /processos/{processoId} {
      allow get, list, create, update, delete: if isSignedIn();
    }
  }
}