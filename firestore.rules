/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles, audit logs, and reports.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/auditLogs/{auditLogId}: Stores audit logs for each user.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by each user.
 * - /partners/{partnerId}: Stores partner information.
 *
 * Key Security Decisions:
 * - Users can only read, update, and delete their own profile data.
 * - Only authenticated users can list user profiles.
 * - Audit logs and reports are only accessible to the owning user.
 * - Partner information is read-only for authenticated users, and write access is disabled.
 *
 * Denormalization for Authorization:
 * - User ownership is enforced by matching the `request.auth.uid` to the `userId` path segment.
 *   This avoids the need for additional reads to verify ownership.
 *
 * Structural Segregation:
 * - Audit logs and reports are stored in user subcollections, ensuring that they are private to the owning user.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @path N/A (Helper function)
     * @allow N/A (Helper function)
     * @deny N/A (Helper function)
     * @principle Verifies user authentication.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @path N/A (Helper function)
     * @allow N/A (Helper function)
     * @deny N/A (Helper function)
     * @principle Enforces document ownership based on user ID.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Rules for user profiles.
     * @path /users/{userId}
     * @allow (get, update, delete) - User 'user123' can access their own profile.
     * @allow (create) - User 'user123' can create their profile if signed in and the userId matches their auth UID.
     * @allow (list) - Any signed-in user can list user profiles.
     * @deny (get, update, delete) - User 'user456' cannot access user 'user123' profile.
     * @deny (create) - User 'user123' cannot create a profile if not signed in.
     * @principle Enforces document ownership for writes and allows listing for signed in users.
     */
    match /users/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn();
    }

    /**
     * @description Rules for audit logs for each user.
     * @path /users/{userId}/auditLogs/{auditLogId}
     * @allow (read, write) - User 'user123' can read and write their own audit logs.
     * @deny (read, write) - User 'user456' cannot access user 'user123' audit logs.
     * @principle Restricts access to a user's own audit logs.
     */
    match /users/{userId}/auditLogs/{auditLogId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    /**
     * @description Rules for reports generated by each user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (read, write) - User 'user123' can read and write their own reports.
     * @deny (read, write) - User 'user456' cannot access user 'user123' reports.
     * @principle Restricts access to a user's own reports.
     */
    match /users/{userId}/reports/{reportId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    /**
     * @description Rules for partner information.
     * @path /partners/{partnerId}
     * @allow (get, list) - Any signed-in user can read partner information.
     * @deny (write) - No one can create, update, or delete partner information.
     * @principle Allows public read access to partner data but restricts write access.
     */
    match /partners/{partnerId} {
      allow get, list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}