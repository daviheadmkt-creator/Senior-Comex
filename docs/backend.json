{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user in the SeniorComex application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "username": {
          "type": "string",
          "description": "The username of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user (Administrator, Operator, Finance, Logistics)."
        }
      },
      "required": [
        "id",
        "username",
        "email",
        "role"
      ]
    },
    "Processo": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Processo",
      "type": "object",
      "description": "Represents a full export/import process.",
      "properties": {
        "id": { "type": "string" },
        "processo_interno": { "type": "string" },
        "data_nomeacao": { "type": "string", "format": "date-time" },
        "po_number": { "type": "string" },
        "produtoNome": { "type": "string" },
        "quantidade": { "type": "string" },
        "exportadorId": { "type": "string" },
        "portoEmbarqueId": { "type": "string" },
        "portoDescargaId": { "type": "string" },
        "status": { "type": "string" },
        "booking_number": { "type": "string" },
        "armadorId": { "type": "string" },
        "navio": { "type": "string" },
        "viagem": { "type": "string" },
        "analistaId": { "type": "string" }
      },
      "required": ["id", "processo_interno", "status"]
    },
    "AuditLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AuditLog",
      "type": "object",
      "description": "Represents an audit log entry for changes made in the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the AuditLog entry."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who made the change. (Relationship: User 1:N AuditLog)"
        },
        "timestamp": {
          "type": "string",
          "description": "Timestamp of when the change was made.",
          "format": "date-time"
        },
        "entityType": {
          "type": "string",
          "description": "The type of entity that was changed (e.g., 'Product', 'Order')."
        },
        "entityId": {
          "type": "string",
          "description": "The ID of the entity that was changed."
        },
        "changeType": {
          "type": "string",
          "description": "The type of change (e.g., 'Create', 'Update', 'Delete')."
        },
        "oldValue": {
          "type": "string",
          "description": "The old value of the field that was changed. JSON formatted."
        },
        "newValue": {
          "type": "string",
          "description": "The new value of the field that was changed. JSON formatted."
        }
      },
      "required": [
        "id",
        "userId",
        "timestamp",
        "entityType",
        "entityId",
        "changeType"
      ]
    },
    "Report": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Report",
      "type": "object",
      "description": "Represents a report generated by the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Report."
        },
        "name": {
          "type": "string",
          "description": "The name of the report."
        },
        "description": {
          "type": "string",
          "description": "A description of the report."
        },
        "dateGenerated": {
          "type": "string",
          "description": "The date and time the report was generated.",
          "format": "date-time"
        },
        "fileUri": {
          "type": "string",
          "description": "The URI where the report file is stored.",
          "format": "uri"
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who generated the report. (Relationship: User 1:N Report)"
        }
      },
      "required": [
        "id",
        "name",
        "dateGenerated",
        "fileUri"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/processos/{processoId}": {
      "schema": { "$ref": "#/entities/Processo" },
      "description": "Stores all export/import process documents."
    },
    "/partners/{partnerId}": {
      "schema": { "type": "object" },
      "description": "Stores partners like clients, suppliers, ship owners, etc."
    },
    "/ports/{portId}": {
      "schema": { "type": "object" },
      "description": "Stores port information."
    },
    "/terminals/{terminalId}": {
      "schema": { "type": "object" },
      "description": "Stores terminal information."
    }
  }
}