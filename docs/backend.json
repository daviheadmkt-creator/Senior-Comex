
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user in the SeniorComex application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "username": {
          "type": "string",
          "description": "The username of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user (Administrator, Operator, Finance, Logistics)."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile photo.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "username",
        "email",
        "role"
      ]
    },
    "Processo": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Processo",
      "type": "object",
      "description": "Represents a full export/import process.",
      "properties": {
        "id": { "type": "string" },
        "processo_interno": { "type": "string" },
        "data_nomeacao": { "type": "string", "format": "date-time" },
        "po_number": { "type": "string" },
        "produtoNome": { "type": "string" },
        "quantidade": { "type": "string" },
        "exportadorId": { "type": "string" },
        "portoEmbarqueId": { "type": "string" },
        "portoDescargaId": { "type": "string" },
        "status": { "type": "string" },
        "booking_number": { "type": "string" },
        "armadorId": { "type": "string" },
        "navio": { "type": "string" },
        "viagem": { "type": "string" },
        "analistaId": { "type": "string" }
      },
      "required": ["id", "processo_interno", "status"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/processos/{processoId}": {
      "schema": { "$ref": "#/entities/Processo" },
      "description": "Stores all export/import process documents."
    },
    "/partners/{partnerId}": {
      "schema": { "type": "object" },
      "description": "Stores partners like clients, suppliers, ship owners, etc."
    },
    "/ports/{portId}": {
      "schema": { "type": "object" },
      "description": "Stores port information."
    },
    "/terminals/{terminalId}": {
      "schema": { "type": "object" },
      "description": "Stores terminal information."
    }
  }
}
